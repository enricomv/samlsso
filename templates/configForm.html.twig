                   role="tab" 
                   aria-controls="logging" 
                   aria-selected="false"><b>{{ __('Logging') }}</b></a>
            </li>
        </ul>
        <div class="tab-content flex-fill glpisaml" id="myTabContent">
            <style>
                .glpisaml .form-field.row {
                    display: flex;
                    align-items: center;
                    justify-content: space-between;
                    flex-wrap: nowrap;
                    margin-bottom: 0.75rem !important;
                    width: 100%;
                }
                .glpisaml .col-form-label,
                .glpisaml label {
                    flex: 1 1 auto !important;
                    width: auto !important;
                    max-width: none !important;
                    display: inline-flex !important;
                    align-items: center !important;
                    justify-content: flex-start !important;
                    flex-wrap: wrap !important;
                    gap: 6px !important;
                    text-align: left !important;
                    padding-right: 15px;
                    word-break: break-word;
                }
                .glpisaml .form-field.row > div:not(.col-form-label) {
                    flex: 0 0 auto !important;
                    width: auto !important;
                    max-width: none !important;
