<!-- implemented in ConfigForm->generateForm() -->
<!-- https://codeberg.org/QuinQuies/glpisaml/issues/13 -->
{% import glpi_tpl_macro as fields %}

<script>
    const SamlSsoPopoverManager = {
        activePopoverInstance: null,
        activePopoverEl: null,
        closeTimeout: null,

        // Initialize a single popover element with consistent hover/click lifecycle rules
        init: function(el, options = {}) {
            const self = this;
            const $el = $(el);

            // Dispose any existing Popover or Tooltip instances to prevent duplicates
            try {
                if (typeof bootstrap !== 'undefined') {
                    const instPopover = bootstrap.Popover.getInstance(el);
                    if (instPopover) instPopover.dispose();
                    const instTooltip = bootstrap.Tooltip.getInstance(el);
                    if (instTooltip) instTooltip.dispose();
                }
            } catch (e) {
                console.error(e);
            }
            if (typeof $.fn.popover === 'function') {
                try { $el.popover('dispose'); } catch(e) {}
            }
            if (typeof $.fn.tooltip === 'function') {
                try { $el.tooltip('dispose'); } catch(e) {}
            }
            
            // Get data-samlsso-type or fallback
            const type = $el.attr('data-samlsso-type') || 'info';
            const customClass = $el.attr('data-bs-custom-class') || `samlsso-popover-${type}`;
            const placement = $el.attr('data-bs-placement') || 'top';
            const html = $el.attr('data-bs-html') !== 'false';
            
            // Determine header title
            let title = $el.attr('data-samlsso-title') || $el.attr('title') || $el.attr('data-bs-original-title') || '';
            const content = $el.attr('data-bs-content') || '';
            if (!title || title === content) {
                if (type === 'error') title = 'Error';
                else if (type === 'warning') title = 'Warning';
                else if (type === 'success') title = 'Success';
                else if (type === 'trace') title = 'Login Flow Trace';
                else title = 'Help';
            }

            // Clear original title attributes to prevent duplicate native rendering
            $el.removeAttr('title').removeAttr('data-bs-original-title');

            // Initialize Bootstrap Popover
            const popoverInstance = new bootstrap.Popover(el, {
                sanitize: false,
                trigger: 'manual',
                customClass: customClass,
                html: html,
                placement: placement,
                container: 'body',
                title: title,
                ...options
            });

            function show() {
                if (self.closeTimeout) {
                    clearTimeout(self.closeTimeout);
                }
                if (self.activePopoverInstance && self.activePopoverInstance !== popoverInstance) {
                    self.activePopoverInstance.hide();
                }
                popoverInstance.show();
                self.activePopoverInstance = popoverInstance;
                self.activePopoverEl = el;
            }

            function delayHide() {
                if (self.closeTimeout) {
                    clearTimeout(self.closeTimeout);
                }
                self.closeTimeout = setTimeout(function() {
                    const activePopover = document.querySelector('.popover');
                    const isTriggerHovered = self.activePopoverEl && self.activePopoverEl.matches(':hover');
                    const isPopoverHovered = activePopover && activePopover.matches(':hover');

                    if (isTriggerHovered || isPopoverHovered) {
                        return; // Keep popover open
                    }

                    popoverInstance.hide();
                    if (self.activePopoverInstance === popoverInstance) {
                        self.activePopoverInstance = null;
                        self.activePopoverEl = null;
                    }
                }, 750);
            }

            $el.on('mouseenter', show);
            $el.on('mouseleave', delayHide);
            $el.on('click', function(e) {
                e.preventDefault();
                e.stopPropagation();
                if (self.activePopoverInstance === popoverInstance) {
                    popoverInstance.hide();
                    self.activePopoverInstance = null;
                    self.activePopoverEl = null;
                } else {
                    show();
                }
            });

            return popoverInstance;
        },

        // Setup global listener rules (click outside, mouseover popover keeping it open, switching tabs)
        setupGlobalListeners: function() {
            const self = this;

            // Keep popover open if mouse is hovering over the popover itself
            document.addEventListener('mouseover', function(e) {
                const targetPopover = e.target.closest('.popover');
                if (targetPopover && self.activePopoverInstance) {
                    if (self.closeTimeout) {
                        clearTimeout(self.closeTimeout);
                    }
                }
            });

            document.addEventListener('mouseout', function(e) {
                const targetPopover = e.target.closest('.popover');
                if (targetPopover && self.activePopoverInstance) {
                    if (e.relatedTarget && e.relatedTarget.closest('.popover') === targetPopover) {
                        return;
                    }
                    if (self.closeTimeout) {
                        clearTimeout(self.closeTimeout);
                    }
                    self.closeTimeout = setTimeout(function() {
                        const activePopover = document.querySelector('.popover');
                        const isTriggerHovered = self.activePopoverEl && self.activePopoverEl.matches(':hover');
                        const isPopoverHovered = activePopover && activePopover.matches(':hover');

                        if (isTriggerHovered || isPopoverHovered) {
                            return; // Keep popover open
                        }

                        if (self.activePopoverInstance) {
                            self.activePopoverInstance.hide();
                            self.activePopoverInstance = null;
                            self.activePopoverEl = null;
                        }
                    }, 750);
                }
            });

            // Hide active popovers when clicking outside
            document.addEventListener('click', function(e) {
                if (self.activePopoverInstance && self.activePopoverEl && !self.activePopoverEl.contains(e.target) && !e.target.closest('.popover')) {
                    self.activePopoverInstance.hide();
                    self.activePopoverInstance = null;
                    self.activePopoverEl = null;
                }
            });

            // Hide active popover when switching tabs
            document.querySelectorAll('.nav-link, [data-bs-toggle="tab"]').forEach(function(tabEl) {
                tabEl.addEventListener('click', function() {
                    if (self.activePopoverInstance) {
                        self.activePopoverInstance.hide();
                        self.activePopoverInstance = null;
                        self.activePopoverEl = null;
                    }
                });
            });
        }
    };

    // Remember tab state
    $(function() {
        SamlSsoPopoverManager.setupGlobalListeners();
        // Destroy all existing qtip tooltips to prevent balloons from staying open on field focus
        if (typeof $.fn.qtip === 'function') {
            try {
                $('.glpisaml *').qtip('destroy', true);
            } catch(e) {}
        }

        if ($.fn.select2) {
            $('#preset_selector').select2();
        }
        
        function toggleFooterVisibility(tabId) {
            if (tabId === '#claim_mapping' || tabId === '#logging') {
                $('.itil-footer').addClass('d-none');
            } else {
                $('.itil-footer').removeClass('d-none');
            }
        }

        $('a[data-bs-toggle="tab"]').on('shown.bs.tab', function (e) {
            var tabId = $(this).attr('href') || $(this).data('bs-target');
            localStorage.setItem('lastTab', tabId);
            toggleFooterVisibility(tabId);
        });
        // Manage d-none class for tabpanels
        $('a[data-bs-toggle="tab"]').on('show.bs.tab', function (e) {
            $($(e.target).attr('href') || $(e.target).data('bs-target')).removeClass('d-none');
        });
        $('a[data-bs-toggle="tab"]').on('hide.bs.tab', function (e) {
            $($(e.target).attr('href') || $(e.target).data('bs-target')).addClass('d-none');
        });

        var lastTab = localStorage.getItem('lastTab');
        
        var urlParams = new URLSearchParams(window.location.search);
        if (urlParams.has('search') || urlParams.has('page')) {
            lastTab = '#logging';
        }
        
        if (lastTab) {
            $('[href="' + lastTab + '"]').tab('show');
        } else {
            var activeTab = $('.nav-tabs .nav-link.active').attr('href') || $('.nav-tabs .nav-link.active').data('bs-target');
            if (activeTab) {
                toggleFooterVisibility(activeTab);
            }
        }

        // Helper to structure label text on the left and all icons/tooltips on the right
        function alignLabelIcons($row) {
            var $label = $row.find('label').first();
            if (!$label.length) {
                $label = $row.find('.col-form-label').first();
            }
            if (!$label.length) return null;
            
            var $iconsSpan = $label.find('.label-icons-part');
            if ($iconsSpan.length) {
                return $iconsSpan;
            }
            
            var text = "";
            $label.contents().each(function() {
                if (this.nodeType === Node.TEXT_NODE) {
                    text += this.nodeValue;
                }
            });
            text = text.trim();
            
            var $icons = $label.contents().filter(function() {
                return this.nodeType !== Node.TEXT_NODE && !$(this).hasClass('label-text-part') && !$(this).hasClass('label-icons-part');
            });
            
            $label.empty();
            
            var $textSpan = $('<span class="label-text-part"></span>').text(text);
            $iconsSpan = $('<span class="label-icons-part"></span>');
            
            $iconsSpan.append($icons);
            $label.append($textSpan).append($iconsSpan);
            return $iconsSpan;
        }

        // Initialize label alignment on all fields
        $('.glpisaml .form-field.row').each(function() {
            alignLabelIcons($(this));
        });

        // Delay scanning and popover manager initialization slightly to run after GLPI core has loaded
        setTimeout(function() {
            // Scan and highlight all fields containing errors across all tabs (only matching true red errors)
            $('.form-text[style*="color:red"], .form-text[style*="color: red"]').each(function() {
                var $errorText = $(this);
                var $row = $errorText.closest('.form-field.row');
                if ($row.length) {
                    // Apply red background styling class
                    $row.addClass('form-field-error-row');
                    
                    // Add error icon next to the label if it's not already there
                    var $iconsSpan = alignLabelIcons($row);
                    if ($iconsSpan && !$iconsSpan.find('.fa-exclamation-triangle.text-danger').length) {
                        var $warnSpan = $('<span class="text-danger ms-1" style="cursor: pointer;" data-samlsso-toggle="popover" data-bs-placement="top" data-bs-html="true" data-samlsso-type="error"><i class="fas fa-exclamation-triangle"></i></span>');
                        $warnSpan.attr('data-bs-content', $errorText.html() || $errorText.text());
                        $warnSpan.attr('title', 'Error');
                        $iconsSpan.prepend($warnSpan);
                        SamlSsoPopoverManager.init($warnSpan[0]);
                    }
                    
                    // Hide the raw error text
                    $errorText.hide();
                }
            });

            // Process warning helper texts (orange/yellow) and convert them to tooltips + warning row background
            $('.form-text[style*="color:rgb(180, 120, 8)"], .form-text[style*="color: rgb(180, 120, 8)"], .form-text[style*="color:rgb(180, 140, 8)"], .form-text[style*="color: rgb(180, 140, 8)"]').each(function() {
                var $warnText = $(this);
                var $row = $warnText.closest('.form-field.row');
                if ($row.length) {
                    // Apply warning row class
                    $row.addClass('form-field-warning-row');
                    
                    // Add warning icon next to the label
                    var $iconsSpan = alignLabelIcons($row);
                    if ($iconsSpan && !$iconsSpan.find('.fa-exclamation-triangle.text-warning').length) {
                        var $warnSpan = $('<span class="text-warning ms-1" style="cursor: pointer;" data-samlsso-toggle="popover" data-bs-placement="top" data-bs-html="true" data-samlsso-type="warning"><i class="fas fa-exclamation-triangle"></i></span>');
                        $warnSpan.attr('data-bs-content', $warnText.html() || $warnText.text());
                        $warnSpan.attr('title', 'Warning');
                        $iconsSpan.prepend($warnSpan);
                        SamlSsoPopoverManager.init($warnSpan[0]);
                    }
                    
                    // Hide the raw warning text
                    $warnText.hide();
                }
            });

            // Clean up and style green informational success text elements
            $('.form-text[style*="color:rgb(3, 126, 26)"], .form-text[style*="color:rgb(71, 180, 8)"]').each(function() {
                var $infoText = $(this);
                var $row = $infoText.closest('.form-field.row');
                if ($row.length) {
                    // Apply info background class
                    $row.addClass('form-field-info-row');
                    
                    // Add info icon next to the label
                    var $iconsSpan = alignLabelIcons($row);
                    if ($iconsSpan && !$iconsSpan.find('.fa-info-circle.text-info').length) {
                        var $infoSpan = $('<span class="text-info ms-1" style="cursor: pointer;" data-samlsso-toggle="popover" data-bs-placement="top" data-bs-html="true" data-samlsso-type="success"><i class="fas fa-info-circle"></i></span>');
                        $infoSpan.attr('data-bs-content', $infoText.html() || $infoText.text());
                        $infoSpan.attr('title', 'Info');
                        $iconsSpan.prepend($infoSpan);
                        SamlSsoPopoverManager.init($infoSpan[0]);
                    }
                    
                    // Hide the raw info text
                    $infoText.hide();
                }
            });

            // Convert Security tab warning icons/tooltips to match General tab warning styles
            $('[id$="_warning_icon"]').each(function() {
                var $icon = $(this);
                var iconId = $icon.attr('id');
                var $row = $icon.closest('.form-field.row');
                var tooltipText = $icon.attr('data-bs-original-title') || $icon.attr('title') || $icon.attr('data-bs-content') || '';
                
                if (!tooltipText && iconId) {
                    var $contentDiv = $('#content' + iconId);
                    if ($contentDiv.length) {
                        tooltipText = $contentDiv.text() || $contentDiv.html();
                        $contentDiv.remove(); // Remove stray tooltip content div
                    }
                }
                
                if (tooltipText && $row.length) {
                    // Remove the native warning icon
                    $icon.remove();
                    
                    // Add yellow warning background styling class
                    $row.addClass('form-field-warning-row');
                    
                    // Add warning yellow triangle indicator to the label
                    var $iconsSpan = alignLabelIcons($row);
                    if ($iconsSpan && !$iconsSpan.find('.fa-exclamation-triangle.text-warning').length) {
                        var $tipSpan = $('<span class="text-warning ms-1" style="cursor: pointer;" data-samlsso-toggle="popover" data-bs-placement="top" data-bs-html="true" data-samlsso-type="warning"><i class="fas fa-exclamation-triangle"></i></span>');
                        $tipSpan.attr('data-bs-content', tooltipText.replace('⚠️', '').trim());
                        $tipSpan.attr('title', 'Warning');
                        $iconsSpan.prepend($tipSpan);
                        SamlSsoPopoverManager.init($tipSpan[0]);
                    }
                }
            });

            // Convert all help icon tooltips/popovers into harmonized popovers
            $('.glpisaml .form-help, .glpisaml [data-bs-toggle="popover"], .glpisaml [data-bs-toggle="tooltip"], .glpisaml .dropdown_tooltip, .glpisaml .fa-question-circle').not('#logging *').each(function() {
                var $help = $(this);
                var $row = $help.closest('.form-field.row');
                
                var helpText = $help.attr('data-bs-title') || $help.attr('data-bs-content') || $help.attr('data-bs-original-title') || $help.attr('title') || '';
                
                // If text is empty, check parent
                if (!helpText) {
                    var $parent = $help.parent();
                    helpText = $parent.attr('data-bs-title') || $parent.attr('data-bs-content') || $parent.attr('data-bs-original-title') || $parent.attr('title') || '';
                }

                // If text is still empty, check children and this element's ID for content divs
                if (!helpText) {
                    var idsToCheck = [];
                    if ($help.attr('id')) idsToCheck.push($help.attr('id'));
                    $help.find('*[id]').each(function() {
                        idsToCheck.push($(this).attr('id'));
                    });
                    for (var i = 0; i < idsToCheck.length; i++) {
                        var $contentDiv = $('#content' + idsToCheck[i]);
                        if ($contentDiv.length) {
                            helpText = $contentDiv.text() || $contentDiv.html();
                            $contentDiv.remove();
                            break;
                        }
                    }
                }

                if (helpText) {
                    alignLabelIcons($row);
                    // Setup attributes for harmonized popover and strip standard data-bs attributes to bypass GLPI
                    $help.attr('data-samlsso-toggle', 'popover')
                         .removeAttr('data-bs-toggle')
                         .removeAttr('data-bs-original-title')
                         .attr('data-bs-placement', 'top')
                         .attr('data-bs-html', 'true')
                         .attr('data-samlsso-type', 'info')
                         .attr('data-bs-content', helpText)
                         .attr('title', 'Help')
                         .css('cursor', 'pointer');
                    
                    // Initialize the popover
                    SamlSsoPopoverManager.init($help[0]);
                }
            });
        }, 150);
    });

    // Get user id and username
    const currentUserId = {{ currentUserId|json_encode|raw }};
    const currentUsername = {{ currentUsername|json_encode|raw }};
    
    var mappingPresets = {{ mapping_presets|json_encode|raw }};
    const allowedUserFields = {{ allowed_user_fields|json_encode|raw }};
    const allowedRuleFields = {{ allowed_rule_fields|json_encode|raw }};
    const observedClaims = {{ observed_claims|json_encode|raw }};

    function applyPreset(presetName) {
        if (!presetName || !mappingPresets[presetName]) {
            return;
        }
        var preset = mappingPresets[presetName];
        var tbody = document.getElementById('claim_mapping_tbody');
        tbody.innerHTML = '';
        rowCounter = 0;

        // username always remains NameId and is added manually
        addRow('user_field', 'username', 'NameId', '', 1);

        for (var field in preset) {
            if (field === 'username') {
                continue; // Skip updating username mapping
            }
            var targetType = (field === 'groups') ? 'rule_field' : 'user_field';
            addRow(targetType, field, preset[field], '', (field === 'email') ? 1 : 0);
        }
        var $tableWrap = $('#claim_mapping_tbody').closest('.table-responsive');
        if (!$tableWrap.length) $tableWrap = $('#claim_mapping_tbody').parent();
        
        var $overlay = $('<div class="preset-loading-overlay"><i class="fas fa-spinner fa-spin fa-3x"></i></div>');
        $overlay.css({
            position: 'absolute',
            top: 0,
            left: 0,
            width: '100%',
            height: '100%',
            background: 'rgba(255, 255, 255, 0.7)',
            display: 'flex',
            alignItems: 'center',
            justifyContent: 'center',
            zIndex: 10
        });
        
        if ($tableWrap.css('position') === 'static') {
            $tableWrap.css('position', 'relative');
        }
        
        $tableWrap.append($overlay);

        setTimeout(function() {
            $overlay.remove();
            if ($.fn.select2) {
                $('#preset_selector').val('').trigger('change.select2');
            } else {
                document.getElementById('preset_selector').value = '';
            }
        }, 500);
    }

    function updateGlpiFields(selectElem) {
        const row = selectElem.closest('tr');
        const glpiSelect = row.querySelector('.glpi-field-select');
        const targetType = selectElem.value;
        
        if (!targetType) {
            glpiSelect.innerHTML = '';
            glpiSelect.classList.add('d-none');
            return;
        }
        
        glpiSelect.innerHTML = '';
        const fields = targetType === 'rule_field' ? allowedRuleFields : allowedUserFields;
        
        fields.forEach(field => {
            const opt = document.createElement('option');
            opt.value = field;
            opt.textContent = field.charAt(0).toUpperCase() + field.slice(1);
            glpiSelect.appendChild(opt);
        });

        glpiSelect.classList.remove('d-none');

        const unusedBadge = row.querySelector('.unused-rule-badge');
        if (unusedBadge) {
            if (targetType !== 'rule_field') {
                unusedBadge.classList.add('d-none');
            } else {
                unusedBadge.classList.remove('d-none');
            }
        }
    }

    let rowCounter = 0;

    function addRow(targetType = '', glpiField = '', samlClaim = '', defaultValue = '', isRequired = 0) {
        const tbody = document.getElementById('claim_mapping_tbody');
        const index = rowCounter++;
        
        const tr = document.createElement('tr');
        tr.className = 'claim-mapping-row';
        tr.setAttribute('data-index', index);
        
        const fields = targetType === 'rule_field' ? allowedRuleFields : allowedUserFields;
        let glpiOptions = '';
        if (targetType) {
            fields.forEach(field => {
                const selected = field === glpiField ? 'selected' : '';
                glpiOptions += `<option value="${field}" ${selected}>${field.charAt(0).toUpperCase() + field.slice(1)}</option>`;
            });
        }

        const isObserved = observedClaims.includes(samlClaim);
        const isUsernameLocked = targetType === 'user_field' && glpiField === 'username';
        const isSystemRequired = targetType === 'user_field' && (glpiField === 'username' || glpiField === 'email');
        const disabledAttr = isSystemRequired ? 'disabled' : '';
        const checkedAttr = (isSystemRequired || isRequired) ? 'checked' : '';
        
        const hiddenInputs = `
            ${isSystemRequired ? `
                <input type="hidden" name="claim_map[${index}][target_type]" value="${targetType}">
                <input type="hidden" name="claim_map[${index}][glpi_field]" value="${glpiField}">
                <input type="hidden" name="claim_map[${index}][is_required]" value="1">
            ` : ''}
            ${isUsernameLocked ? `
                <input type="hidden" name="claim_map[${index}][saml_claim]" value="NameId">
            ` : ''}
        `;
        
        const deleteButton = isSystemRequired ? '' : `
            <button type="button" class="btn btn-outline-danger btn-sm" onclick="deleteRow(this)">
                <i class="fas fa-trash"></i> Delete
            </button>
        `;

        let dropdownHtml = '';
        if (!isUsernameLocked && observedClaims.length > 0) {
            dropdownHtml += `
                <button class="btn btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" data-bs-boundary="viewport" aria-expanded="false"></button>
                <ul class="dropdown-menu dropdown-menu-end" style="max-height: 200px; overflow-y: auto;">
            `;
            observedClaims.forEach(claim => {
                dropdownHtml += `<li><a class="dropdown-item" href="#" onclick="selectClaim(this, '${claim}'); return false;">${claim}</a></li>`;
            });
            dropdownHtml += `</ul>`;
        }
        
        tr.innerHTML = `
            <td>
                ${hiddenInputs}
                <select name="claim_map[${index}][target_type]" class="form-select target-type-select" onchange="updateGlpiFields(this)" ${disabledAttr}>
                    <option value="" ${targetType === '' ? 'selected' : ''}>-- Select Target Type --</option>
                    <option value="user_field" ${targetType === 'user_field' ? 'selected' : ''}>User Field</option>
                    <option value="rule_field" ${targetType === 'rule_field' ? 'selected' : ''}>Rule Field</option>
                </select>
            </td>
            <td>
                <select name="claim_map[${index}][glpi_field]" class="form-select glpi-field-select ${targetType === '' ? 'd-none' : ''}" ${disabledAttr}>
                    ${glpiOptions}
                </select>
            </td>
            <td>
                <div class="input-group">
                    <input type="text" name="claim_map[${index}][saml_claim]" value="${isUsernameLocked ? 'NameId' : samlClaim}" class="form-control saml-claim-input" oninput="checkObserved(this)" ${isUsernameLocked ? 'disabled' : 'list="observed_claims_list"'}>
                    ${dropdownHtml}
                </div>
            </td>
            <td>
                <input type="text" name="claim_map[${index}][default_value]" value="${defaultValue}" class="form-control">
            </td>
            <td class="text-center">
                <input type="checkbox" name="claim_map[${index}][is_required]" value="1" class="form-check-input" ${checkedAttr} ${disabledAttr}>
            </td>
            <td>
                <div class="status-indicators d-flex align-items-center gap-2">
                    <span class="badge bg-success observed-badge ${((isUsernameLocked || samlClaim) && (isUsernameLocked || isObserved)) ? '' : 'd-none'}">✅ Observed</span>
                    <span class="badge bg-warning unobserved-badge ${(!isUsernameLocked && samlClaim && !isObserved) ? '' : 'd-none'}">⚠️ Unobserved</span>
                </div>
            </td>
            <td>
                ${deleteButton}
            </td>
        `;
        
        tbody.appendChild(tr);
    }

    function selectClaim(linkElem, claimValue) {
        const input = linkElem.closest('.input-group').querySelector('.saml-claim-input');
        input.value = claimValue;
        checkObserved(input);
    }

    function checkObserved(inputElem) {
        const row = inputElem.closest('tr');
        const val = inputElem.value.trim();
        const observedBadge = row.querySelector('.observed-badge');
        const unobservedBadge = row.querySelector('.unobserved-badge');
        
        if (val === '') {
            observedBadge.classList.add('d-none');
            unobservedBadge.classList.add('d-none');
            return;
        }
        
        if (observedClaims.includes(val) || val === 'NameId') {
            observedBadge.classList.remove('d-none');
            unobservedBadge.classList.add('d-none');
        } else {
            observedBadge.classList.add('d-none');
            unobservedBadge.classList.remove('d-none');
        }
    }

    function deleteRow(btnElem) {
        btnElem.closest('tr').remove();
    }

    function highlightXml(xml) {
        if (!xml) return '';
        let escaped = xml
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;');

        // Highlight XML comments first so they don't get matched by tag highlights
        let comments = [];
        escaped = escaped.replace(/&lt;!--[\s\S]*?--&gt;/g, function(match) {
            comments.push(match);
            return '___COMMENT_PLACEHOLDER_' + (comments.length - 1) + '___';
        });

        // Highlight tags, attributes, and values
        escaped = escaped.replace(/(&lt;\/?[a-zA-Z0-9_:-]+)([\s\S]*?)((\/?&gt;)|(&gt;))/g, function(match, tagName, attrs, tagEnd) {
            let highlightedAttrs = attrs.replace(/([a-zA-Z0-9_:-]+)=("([^"]*)"|'([^']*)')/g, function(attrMatch, attrName, attrVal) {
                return ' <span class="xml-attr">' + attrName + '</span>=<span class="xml-val">' + attrVal + '</span>';
            });
            return '<span class="xml-tag">' + tagName + '</span>' + highlightedAttrs + '<span class="xml-tag">' + tagEnd + '</span>';
        });

        // Restore comments
        escaped = escaped.replace(/___COMMENT_PLACEHOLDER_(\d+)___/g, function(match, index) {
            return '<span class="xml-comment">' + comments[parseInt(index, 10)] + '</span>';
        });

        return escaped;
    }
</script>

