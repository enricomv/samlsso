                                                <div id="textHelper" class="form-text" style="color:red;">{{ inputfields.compress_responses.errors }}</div>
                                            {% endif %}
                                        {% endset %}
                                        {{ fields.sliderField(
                                            inputfields.compress_responses.field,
                                            inputfields.compress_responses.value,
                                            inputfields.compress_responses.formtitle,
                                           {
                                              'add_field_html': error_helper,
                                               helper: inputfields.compress_responses.formexplain,
                                           }
                                        ) }}
                                    </div>
                                </div>
                            </div>

                            <!-- Group 2: Proxied & Encoding -->
                            <div class="card">
                                <div class="card-header py-2 px-3">
                                    <h6 class="card-title mb-0 text-uppercase text-muted"><i class="fas fa-network-wired me-2 text-primary"></i>{{ __('Proxied & Encoding', plugin) }}</h6>
                                </div>
                                <div class="card-body p-3">
                                    <!-- Proxied -->
                                    <div class="mb-3">
                                        {% set error_helper %}
                                            {% if inputfields.proxied.errors == true %}
                                                <div id="textHelper" class="form-text" style="color:red;">{{ inputfields.proxied.errors }}</div>
                                            {% endif %}
                                            {% if inputfields.proxied.value == true %}
                                                {% if inputfields.strict.value == true %}
                                                    <div id="textHelper" class="form-text" style="color:rgb(180, 120, 8);">{{ __('⚠️ Beware, misaligned proxy schemes might break the samlValidation in strict mode.<br>(<b>https</b>://external)=>(<b>http</b>://internal)', plugin)|raw }}</div>
                                                {% endif %}
                                            {% endif %}
                                        {% endset %}
                                        {{ fields.sliderField(
                                            inputfields.proxied.field,
                                            inputfields.proxied.value,
                                            inputfields.proxied.formtitle,
                                           {
                                              'add_field_html': error_helper,
                                               helper: inputfields.proxied.formexplain,
                                           }
                                        ) }}
                                    </div>

                                    <!-- lowercase_url_encoding -->
                                    <div class="mb-3">
                                        {% set error_helper %}
                                            {% if inputfields.lowercase_url_encoding.errors == true %}
                                                <div id="textHelper" class="form-text" style="color:red;">{{ inputfields.lowercase_url_encoding.errors }}</div>
                                            {% endif %}
                                        {% endset %}
                                        {{ fields.sliderField(
                                            inputfields.lowercase_url_encoding.field,
                                            inputfields.lowercase_url_encoding.value,
                                            inputfields.lowercase_url_encoding.formtitle,
                                           {
                                              'add_field_html': error_helper,
                                               helper: inputfields.lowercase_url_encoding.formexplain,
                                           }
                                        ) }}
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-6 mb-4">
                            <!-- Group 3: XML & Destination Validation -->
                            <div class="card" style="height: 100%;">
                                <div class="card-header py-2 px-3">
                                    <h6 class="card-title mb-0 text-uppercase text-muted"><i class="fas fa-check-double me-2 text-primary"></i>{{ __('XML & Destination Validation', plugin) }}</h6>
                                </div>
                                <div class="card-body p-3">
                                    <!-- validate_xml -->
                                    <div class="mb-3">
                                        {% set error_helper %}
                                            {% if inputfields.validate_xml.errors == true %}
                                                <div id="textHelper" class="form-text" style="color:red;">{{ inputfields.validate_xml.errors }}</div>
                                            {% endif %}
                                            {% if inputfields.strict.value == false %}
                                                <div id="textHelper" class="form-text" style="color:rgb(180, 120, 8);">{{ __('⚠️ Strict is disabled, validate xml setting will not do anything.', plugin) }}</div>
                                            {% endif %}
                                        {% endset %}
                                        {{ fields.sliderField(
                                            inputfields.validate_xml.field,
                                            inputfields.validate_xml.value,
                                            inputfields.validate_xml.formtitle,
                                           {
                                              'add_field_html': error_helper,
                                               helper: inputfields.validate_xml.formexplain,
                                           }
                                        ) }}
                                    </div>

                                    <!-- validate_destination -->
                                    <div class="mb-3">
                                        {% set error_helper %}
                                            {% if inputfields.validate_destination.errors == true %}
                                                <div id="textHelper" class="form-text" style="color:red;">{{ inputfields.validate_destination.errors }}</div>
                                            {% endif %}
                                        {% endset %}
                                        {{ fields.sliderField(
                                            inputfields.validate_destination.field,
                                            inputfields.validate_destination.value,
                                            inputfields.validate_destination.formtitle,
                                           {
                                              'add_field_html': error_helper,
                                               helper: inputfields.validate_destination.formexplain,
                                           }
                                        ) }}
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ################################################################################-->
            <div class="tab-pane fade d-none" id="provider" role="tabpanel" aria-labelledby="provider-tab">
                <div class="card-body">
                    <div class="row">
                        <div class="col-12 col-lg-6 mb-4">
                            <!-- Group 1: Endpoints & Metadata -->
                            <div class="card mb-4">
                                <div class="card-header py-2 px-3">
                                    <h6 class="card-title mb-0 text-uppercase text-muted"><i class="fas fa-network-wired me-2 text-primary"></i>{{ __('Endpoints & Metadata', plugin) }}</h6>
                                </div>
                                <div class="card-body p-3">
                                    <!-- Entity ID -->
                                    <div class="mb-3">
                                        {{ fields.textField(
                                            'EntityID', 
                                            entityID, 
                                            __('Entity ID', plugin),
                                            {
                                                'id': 'EntityId',
                                                'readonly':true,
                                                'is_copyable': true,
                                                helper: __('You need to configure the Entity ID at the identity provider. This value is crosschecked by the identity provider to make sure the sign-in request is originating from the correct service provider.', plugin),
                                            }
                                        ) }}
                                    </div>

                                    <!-- Meta URL -->
                                    <div class="mb-3">
                                        {% set metaUrl %}
                                            <div class="btn-group btn-group-sm d-flex">
                                                <input type="text" id="MetaUrl" class="form-control rounded-end-0" name="MetaUrl" value="{{ metaUrl }}" readonly="readonly">
                                                {% if inputfields.debug.value == false %}
                                                    {% set rand = random() %}
                                                    <button type="button" id="meta_warning_{{ rand }}" class="btn btn-outline-secondary">
                                                        <i class="ti ti-alert-triangle"></i>
                                                    </button>
                                                    {% do call('Html::showToolTip', [
                                                        "Debug is disabled, metadata will only be exposed if 'debug' is enabled.",
                                                        {'applyto': 'meta_warning_' ~ rand}
                                                    ]) %}
                                                {% endif %}
                                                <button type="button" class="btn btn-outline-secondary" onclick="copyDisclosablePasswordFieldToClipboard('MetaUrl')">
                                                    <i class="ti ti-clipboard-copy disclose"></i>
                                                </button>
                                            </div>
                                        {% endset %}
                                        {{ fields.field(
                                            'MetaUrl', 
                                            metaUrl, 
                                            __('MetaUrl', plugin),
                                            {
                                                helper: __('The location of the metadata provider for this service provider (GLPI). The meta location can be used by the identity provider to collect important information from this service provider like what public certificate to use for signing and encrypting the SamlResponse.', plugin),
                                            }
                                        ) }}
                                    </div>
                                   
                                    <!-- ACS url -->
                                    <div class="mb-3">
                                        {{ fields.textField(
                                            'AcsUrl', 
                                            acsUrl, 
                                            __('AcsUrl', plugin),
                                            {
                                                'id': 'AcsUrl',
                                                'readonly':true,
                                                'is_copyable': true,
                                                helper: __('The location of the Assertion Consumer Service (ACS) for this service provider (GLPI). This url is called by the identity provider after succesfull login.', plugin),
                                            }
                                        ) }}
                                    </div>

                                    <!-- Logout url -->
                                    <div class="mb-3">
                                        {{ fields.textField(
                                            'SloUrl', 
                                             sloUrl, 
                                            __('SloUrl', plugin),
                                            {
                                                'id': 'SloUrl',
                                                'readonly':true,
                                                'is_copyable': true,
                                                helper: __('The location where logout requests should be send back to from the Identity Provider.', plugin),
                                            }
                                        ) }}
                                    </div>
                                </div>
                            </div>

                            <!-- Group 2: Name ID Policy -->
                            <div class="card">
                                <div class="card-header py-2 px-3">
                                    <h6 class="card-title mb-0 text-uppercase text-muted"><i class="fas fa-fingerprint me-2 text-primary"></i>{{ __('Name ID Policy', plugin) }}</h6>
                                </div>
                                <div class="card-body p-3">
                                    <div class="mb-3">
                                        {% set error_helper %}
                                            {% if inputfields.sp_nameid_format.errors == true %}
                                                <div id="textHelper" class="form-text" style="color:red;">{{ inputfields.sp_nameid_format.errors }}</div>
                                            {% endif %}
                                        {% endset %}

                                        {{ fields.dropdownArrayField(
                                            inputfields.sp_nameid_format.field,
                                            inputfields.sp_nameid_format.value,
                                            inputOptionsNameFormat,
                                            inputfields.sp_nameid_format.formtitle,
                                            {
                                                'add_field_html': error_helper,
                                                helper: inputfields.sp_nameid_format.formexplain,
                                            }
                                        ) }}
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-6 mb-4">
                            <!-- Group 3: Certificates & Keys -->
                            <div class="card" style="height: 100%;">
                                <div class="card-header py-2 px-3">
                                    <h6 class="card-title mb-0 text-uppercase text-muted"><i class="fas fa-key me-2 text-primary"></i>{{ __('Certificates & Keys', plugin) }}</h6>
                                </div>
                                <div class="card-body p-3">
                                    <!-- sp_certificate -->
                                    <div class="mb-3">
                                        {% set error_helper %}
                                            {% if inputfields.sp_private_key.errors == true %}
                                                <div id="textHelper" class="form-text" style="color:red;">{{ inputfields.sp_private_key.errors }}</div>
                                            {% endif %}
                                            {% if inputfields.sp_certificate.errors == true %}
                                                <div id="textHelper" class="form-text" style="color:red;">{{ inputfields.sp_certificate.errors }}</div>
                                            {% endif %}
                                            {# make sure validate is an array/object before accessing nested keys #}
                                            {% set sp_validate = inputfields.sp_certificate.validate|default({}) %}
                                            {% if sp_validate.subject.CN|default(false) == true %}
                                                <div id="textHelper" class="form-text" style="color:rgb(71, 180, 8);">🆗 Valid certificate found: {{ sp_validate.subject.CN|default('') }}</div>
                                            {% endif %}
                                            {% if sp_validate.validations.validTo|default(false) == true %}
                                                <div id="textHelper" class="form-text" style="color:rgb(180, 120, 8);">{{ sp_validate.validations.validTo|default('') }}</div>
                                            {% endif %}
                                            {% if sp_validate.validations.validFrom|default(false) == true %}
                                                <div id="textHelper" class="form-text" style="color:rgb(180, 120, 8);">{{ sp_validate.validations.validFrom|default('') }}</div>
                                            {% endif %}
                                        {% endset %}
                                        
                                        {{ fields.textareaField(
                                            inputfields.sp_certificate.field,
                                            inputfields.sp_certificate.value,
                                            inputfields.sp_certificate.formtitle,
                                            {
                                                'add_field_html': error_helper,
                                                helper: inputfields.sp_certificate.formexplain,
                                            }) 
                                        }}
                                    </div>

                                    <!-- sp_private_key -->
                                    <div class="mb-3">
                                        {{ fields.textareaField( 
                                            inputfields.sp_private_key.field,
                                            inputfields.sp_private_key.value,
                                            inputfields.sp_private_key.formtitle,
                                            {
                                                helper: inputfields.sp_private_key.formexplain,
                                            }) 
                                        }}
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ################################################################################-->
            <!-- Identity provider details -->
            <div class="tab-pane fade d-none" id="idp" role="tabpanel" aria-labelledby="idp-tab">
                <div class="card-body">
                    <div class="row">
                        <div class="col-12 col-lg-6 mb-4">
                            <!-- Group 1: Endpoints & Configurations -->
                            <div class="card mb-4">
                                <div class="card-header py-2 px-3">
                                    <h6 class="card-title mb-0 text-uppercase text-muted"><i class="fas fa-network-wired me-2 text-success"></i>{{ __('Endpoints & Configurations', plugin) }}</h6>
                                </div>
                                <div class="card-body p-3">
                                     <!-- idp_entity_id -->
                                     <div class="mb-3">
                                        {% set error_helper %}
                                            {% if inputfields.idp_entity_id.errors == true %}
                                                <div id="textHelper" class="form-text" style="color:red;">{{ inputfields.idp_entity_id.errors }}</div>
                                            {% endif %}
                                        {% endset %}

                                        {{ fields.textField( 
                                            inputfields.idp_entity_id.field, 
                                            inputfields.idp_entity_id.value, 
                                            inputfields.idp_entity_id.formtitle, 
                                            {
                                                'add_field_html': error_helper,
                                                helper: inputfields.idp_entity_id.formexplain,
                                            }) 
                                        }}
                                    </div>

                                    <!-- idp_single_sign_on_service -->
                                    <div class="mb-3">
                                        {% set error_helper %}
                                            {% if inputfields.idp_single_sign_on_service.errors == true %}
                                                <div id="textHelper" class="form-text" style="color:red;">{{ inputfields.idp_single_sign_on_service.errors }}</div>
                                            {% endif %}
                                        {% endset %}

                                        {{ fields.textField( 
                                            inputfields.idp_single_sign_on_service.field, 
                                            inputfields.idp_single_sign_on_service.value, 
                                            inputfields.idp_single_sign_on_service.formtitle ~ helper|raw, 
                                            {
                                                'add_field_html': error_helper,
                                                helper: inputfields.idp_single_sign_on_service.formexplain,
                                            }) 
                                        }}
                                    </div>

                                    <!-- idp_single_logout_service -->
                                    <div class="mb-3">
                                        {% set error_helper %}
                                            {% if inputfields.idp_single_logout_service.errors == true %}
                                                <div id="textHelper" class="form-text" style="color:red;">{{ inputfields.idp_single_logout_service.errors }}</div>
                                            {% endif %}
                                        {% endset %}

                                        {{ fields.textField( 
                                            inputfields.idp_single_logout_service.field, 
                                            inputfields.idp_single_logout_service.value, 
                                            inputfields.idp_single_logout_service.formtitle ~ helper|raw, 
                                            {
                                                'add_field_html': error_helper,
                                                helper: inputfields.idp_single_logout_service.formexplain,
                                            }) 
                                        }}
                                    </div>
                                </div>
                            </div>

                            <!-- Group 2: Authentication Context -->
                            <div class="card">
                                <div class="card-header py-2 px-3">
                                    <h6 class="card-title mb-0 text-uppercase text-muted"><i class="fas fa-key me-2 text-success"></i>{{ __('Authentication Context', plugin) }}</h6>
                                </div>
                                <div class="card-body p-3">
                                    <!-- requested_authn_context (multiple select) -->
                                    <div class="mb-3">
                                        <div class="form-field row col-12 mb-2">
                                            <div class="col-form-label text-xxl-end">
                                                <label for="{{ inputfields.requested_authn_context.field }}">{{ inputfields.requested_authn_context.formtitle }}</label>
                                                <span class="form-help" data-bs-toggle="popover" data-bs-placement="top" data-bs-html="true"
                                                    data-bs-content="{{ inputfields.requested_authn_context.formexplain }}">?</span>
                                            </div>
                                            <div class="field-container">
                                                <!--
                                                @see: https://codeberg.org/QuinQuies/glpisaml/issues/14
                                                Todo: add nicer, userfriendly drag-drop element
                                                -->
                                                <select id="keep-order" multiple="multiple" aria-label="multiple select" name="{{ inputfields.requested_authn_context.field }}[]">
                                                    {% for key, authn in inputOptionsAuthnContext %}
                                                        {% set selected = false %}
                                                        {% for value in inputfields.requested_authn_context.value %}
                                                            {% if value == key %}
                                                                {% set selected = 'selected' %}
                                                            {% endif %}
                                                        {% endfor %}
                                                        <option {{ selected }} value="{{ key }}">{{ authn }}</option>
                                                    {% endfor %}
                                                </select>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- requested_authn_context_comparison -->
                                    <div class="mb-3">
                                        {% set error_helper %}
                                            {% if inputfields.requested_authn_context_comparison.errors == true %}
                                                <div id="textHelper" class="form-text" style="color:red;">{{ inputfields.requested_authn_context_comparison.errors }}</div>
                                            {% endif %}
                                        {% endset %}

                                        {{ fields.dropdownArrayField( 
                                            inputfields.requested_authn_context_comparison.field,
                                            inputfields.requested_authn_context_comparison.value,
                                            inputOptionsAuthnCompare,
                                            inputfields.requested_authn_context_comparison.formtitle ~ helper|raw, 
                                            {
                                                'add_field_html': error_helper,
                                                helper: inputfields.requested_authn_context_comparison.formexplain,
                                            }) 
                                        }}
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-6 mb-4">
                            <!-- Group 3: Identity Provider Certificates -->
                            <div class="card" style="height: 100%;">
                                <div class="card-header py-2 px-3">
                                    <h6 class="card-title mb-0 text-uppercase text-muted"><i class="fas fa-certificate me-2 text-success"></i>{{ __('Identity Provider Certificates', plugin) }}</h6>
                                </div>
                                <div class="card-body p-3">
                                    <!-- idp_certificate -->
                                    <div class="mb-3">
                                        {% set error_helper %}
                                            {% if inputfields.idp_certificate.errors == true %}
                                                <div id="textHelper" class="form-text" style="color:red;">{{ inputfields.idp_certificate.errors }}</div>
                                            {% endif %}
                                            {% if inputfields.idp_certificate.validate.subject.CN == true %}
                                                <div id="textHelper" class="form-text" style="color:rgb(71, 180, 8);">🆗 Valid Certificate found: {{ inputfields.idp_certificate.validate.subject.CN }}</div>
                                            {% endif %}
                                            {% if inputfields.idp_certificate.validate.validations.validTo == true %}
                                                <div id="textHelper" class="form-text" style="color:rgb(180, 140, 8);">{{ inputfields.idp_certificate.validate.validations.validTo }}</div>
                                            {% endif %}
                                            {% if inputfields.idp_certificate.validate.validations.validFrom == true %}
                                                <div id="textHelper" class="form-text" style="color:rgb(180, 140, 8);">{{ inputfields.idp_certificate.validate.validations.validFrom }}</div>
                                            {% endif %}
                                        {% endset %}

                                        {{ fields.textareaField( 
                                            inputfields.idp_certificate.field, 
                                            inputfields.idp_certificate.value, 
                                            inputfields.idp_certificate.formtitle, 
                                            {
                                                'add_field_html': error_helper,
                                                helper: inputfields.idp_certificate.formexplain,
                                            }) 
                                        }}
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Security details -->
            <div class="tab-pane fade d-none" id="security" role="tabpanel" aria-labelledby="security-tab">
                <div class="card-body">
                    <div class="row">
                        <div class="col-12 col-lg-6 mb-4">
                            <!-- Group 1: Enforcement & Sessions -->
                            <div class="card mb-4">
                                <div class="card-header py-2 px-3">
                                    <h6 class="card-title mb-0 text-uppercase text-muted"><i class="fas fa-shield-alt me-2 text-primary"></i>{{ __('Enforcement & Sessions', plugin) }}</h6>
                                </div>
                                <div class="card-body p-3">
                                    <!-- enforce SSO -->
                                    <div class="mb-3">
                                        {% set enforce_sso_title %}
                                            {{ inputfields.enforce_sso.formtitle }}
                                            {% if inputfields.enforce_sso.errors == true %}
                                                <span class="text-danger ms-1" id="enforce_sso_warning_icon" style="cursor: pointer;">
                                                    <i class="fas fa-exclamation-triangle"></i>
                                                </span>
                                                {% do call('Html::showToolTip', [
                                                    inputfields.enforce_sso.errors,
                                                    {'applyto': 'enforce_sso_warning_icon'}
                                                ]) %}
                                            {% endif %}
                                        {% endset %}
                                        {{ fields.sliderField(
                                            inputfields.enforce_sso.field,
                                            inputfields.enforce_sso.value,
                                            enforce_sso_title|raw,
                                            {
                                                'add_field_html': '',
                                                helper: inputfields.enforce_sso.formexplain,
                                            }
                                        ) }}
                                    </div>

                                    <!-- Request Expiry Timeout -->
                                    <div class="mb-3">
                                        {% set error_helper %}
                                            {% if inputfields.request_timeout.errors == true %}
                                                <div id="textHelper" class="form-text" style="color:red;">{{ inputfields.request_timeout.errors }}</div>
                                            {% endif %}
                                        {% endset %}
                                        {{ fields.textField(
                                            inputfields.request_timeout.field,
                                            inputfields.request_timeout.value,
                                            inputfields.request_timeout.formtitle,
                                            {
                                                'add_field_html': error_helper,
                                                'type': 'number',
                                                helper: inputfields.request_timeout.formexplain,
                                            }
                                        ) }}
                                    </div>

                                    <!-- Inactivity Timeout -->
                                    <div class="mb-3">
                                        {% set error_helper %}
                                            {% if inputfields.inactivity_timeout.errors == true %}
                                                <div id="textHelper" class="form-text" style="color:red;">{{ inputfields.inactivity_timeout.errors }}</div>
                                            {% endif %}
                                        {% endset %}
                                        {{ fields.textField(
                                            inputfields.inactivity_timeout.field,
                                            inputfields.inactivity_timeout.value,
                                            inputfields.inactivity_timeout.formtitle,
                                            {
                                                'add_field_html': error_helper,
                                                'type': 'number',
                                                helper: inputfields.inactivity_timeout.formexplain,
                                            }
                                        ) }}
                                    </div>

                                    <!-- Strict mode -->
                                    <div class="mb-3">
                                        {% set strict_title %}
                                            {{ inputfields.strict.formtitle }}
                                            {% if inputfields.strict.value == false %}
                                                <span class="text-danger ms-1" id="strict_warning_icon" style="cursor: pointer;">
                                                    <i class="fas fa-exclamation-triangle"></i>
                                                </span>
                                                {% do call('Html::showToolTip', [
                                                    __('⚠️ Your environment is at risk, make sure strict is enabled!', plugin),
                                                    {'applyto': 'strict_warning_icon'}
                                                ]) %}
                                            {% endif %}
                                        {% endset %}
                                        {% set error_helper %}
                                            {% if inputfields.strict.errors == true %}
                                                <div id="textHelper" class="form-text" style="color:red;">{{ inputfields.strict.errors }}</div>
                                            {% endif %}
                                        {% endset %}
                                        {{ fields.sliderField(
                                            inputfields.strict.field,
                                            inputfields.strict.value,
                                            strict_title|raw,
                                            {
                                                'add_field_html': error_helper|raw,
                                                helper: inputfields.strict.formexplain,
                                            }
                                        ) }}
                                    </div>
                                </div>
                            </div>

                            <!-- Group 2: User Provisioning -->
                            <div class="card">
                                <div class="card-header py-2 px-3">
                                    <h6 class="card-title mb-0 text-uppercase text-muted"><i class="fas fa-users-cog me-2 text-primary"></i>{{ __('User Provisioning', plugin) }}</h6>
                                </div>
                                <div class="card-body p-3">
                                    <!-- User JIT -->
                                    <div class="mb-3">
                                        {% set error_helper %}
                                            {% if inputfields.user_jit.errors == true %}
                                                <div id="textHelper" class="form-text" style="color:red;">{{ inputfields.user_jit.errors }}</div>
                                            {% endif %}
                                        {% endset %}
                                        {{ fields.sliderField(
                                            inputfields.user_jit.field,
                                            inputfields.user_jit.value,
                                            inputfields.user_jit.formtitle,
                                            {
                                                'add_field_html': error_helper,
                                                helper: inputfields.user_jit.formexplain,
                                            }
                                        ) }}
                                    </div>

                                    <!-- Sync on login -->
                                    <div class="mb-3">
                                        {% set sync_on_login_title %}
                                            {{ inputfields.sync_on_login.formtitle }}
                                            <span class="text-danger ms-1" id="sync_on_login_warning_icon" style="cursor: pointer;">
                                                <i class="fas fa-exclamation-triangle"></i>
                                            </span>
                                            {% do call('Html::showToolTip', [
                                                __('Enabling this field might cause data leak incidents because samlSSO will apply configuration mistakes made at the IDP directly into GLPI.', plugin),
                                                {'applyto': 'sync_on_login_warning_icon'}
                                            ]) %}
                                        {% endset %}
                                        {% set error_helper %}
                                            {% if inputfields.sync_on_login.errors == true %}
                                                <div id="textHelper" class="form-text" style="color:red;">{{ inputfields.sync_on_login.errors }}</div>
                                            {% endif %}
                                        {% endset %}
                                        {{ fields.sliderField(
                                            inputfields.sync_on_login.field,
                                            inputfields.sync_on_login.value,
                                            sync_on_login_title|raw,
                                            {
                                                'add_field_html': error_helper|raw,
                                                helper: inputfields.sync_on_login.formexplain,
                                            }
                                        ) }}
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-6 mb-4">
                            <!-- Group 3: Inbound Security (IdP) -->
                            <div class="card mb-4">
                                <div class="card-header py-2 px-3">
