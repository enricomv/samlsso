            </div>
            <!-- ################################################################################-->
            <!-- Claim Mapping details -->
            <div class="tab-pane fade" id="claim_mapping" role="tabpanel" aria-labelledby="claim-mapping-tab">
                <style>
                    #xml_highlighted_code { color: #24292e; }
                    .xml-tag { color: #d73a49; font-weight: bold; }
                    .xml-attr { color: #6f42c1; }
                    .xml-val { color: #032f62; }
                    .xml-comment { color: #6a737d; font-style: italic; }
                    #samlsso-mapping-tools-collapse .select2-container .select2-selection.select2-selection--single .select2-selection__rendered::before {
                        display: inline !important;
                    }
                </style>
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="card-title mb-0">{{ __('SAML Claim Mapping', plugin) }}</h5>
                        <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-toggle="collapse" data-bs-target="#samlsso-mapping-tools-collapse" aria-expanded="false" aria-controls="samlsso-mapping-tools-collapse">
                            <i class="fas fa-tools me-1"></i>{{ __('Mapping Tools', plugin) }}
                        </button>
                    </div>

                    <!-- Collapsible Mapping Tools Panel -->
                    <div class="collapse mb-4" id="samlsso-mapping-tools-collapse">
                        <div class="card card-body bg-light border-0 shadow-sm p-3">
                            <h6 class="fw-bold mb-2 text-dark"><i class="fas fa-info-circle me-1"></i>{{ __('Mapping Assistant', plugin) }}</h6>
                            <p class="text-muted mb-3" style="font-size: 0.85rem;">
                                {{ __('Map SAML response claim keys dynamically either directly to user profile fields or as JIT Rule criteria. Configure defaults and required verification checks.', plugin) }}
                            </p>

                            <!-- Preset selection and XML toggle -->
                            <div class="row align-items-center g-3">
                                <div class="col-md-7">
                                    <div class="d-flex align-items-center">
                                        <label class="mb-0 me-3 fw-bold" style="white-space: nowrap;">{{ __('Apply Preset', plugin) }}</label>
                                        <select id="preset_selector" class="form-select form-select-sm" onchange="applyPreset(this.value)">
                                            <option value="">-- {{ __('Select Preset', plugin) }} --</option>
                                            {% for name, preset in mapping_presets %}
                                                <option value="{{ name }}">{{ name|title }}</option>
                                            {% endfor %}
                                        </select>
                                    </div>
                                </div>
                                <div class="col-md-5 text-end">
                                    <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-toggle="collapse" data-bs-target="#samlsso-xml-collapse" aria-expanded="false" aria-controls="samlsso-xml-collapse">
                                        <i class="fas fa-code me-1"></i>{{ __('View observed samlResponse XML', plugin) }}
                                    </button>
                                </div>
                            </div>

                            <!-- Collapsible SAML Response XML structure inside the assistant -->
                            <div class="collapse mt-3" id="samlsso-xml-collapse">
                                <div class="border rounded bg-white p-3">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <span class="fw-bold text-muted small"><i class="fas fa-code"></i> {{ __('Sanitized SAML Response XML Structure', plugin) }}</span>
                                    </div>
                                    {% if saml_xml_structure is not empty %}
                                        <div class="alert alert-info py-2 px-3 mb-2 small">
                                            <i class="fas fa-info-circle text-primary me-1"></i>{{ __('This shows the structure of the last received SAML Response. Cryptographic keys, signatures, digests, and PII text node values have been stripped.', plugin) }}
                                        </div>
                                        <pre class="bg-light p-3 border rounded font-monospace mb-0" style="max-height: 450px; overflow-y: auto;"><code id="xml_highlighted_code"></code></pre>
                                    {% else %}
                                        <p class="text-muted mb-0 small"><i class="fas fa-info-circle"></i> {{ __('No SAML response has been recorded yet. Perform a successful login to populate this view.', plugin) }}</p>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </div>

                    <hr>

                    <datalist id="observed_claims_list">
                        {% for claim in observed_claims %}
                            <option value="{{ claim }}"></option>
                        {% endfor %}
                    </datalist>

                    <!-- Dynamic Mapping Grid -->
                    {% if claim_errors is not empty %}
                        <div class="alert alert-danger mb-4">
                            <h5 class="alert-heading"><i class="fas fa-exclamation-triangle me-2"></i>{{ __('Claim Mapping Validation Errors', plugin) }}</h5>
                            <ul class="mb-0">
                                {% for key, err in claim_errors %}
                                    <li>{{ err }}</li>
                                {% endfor %}
                            </ul>
                        </div>
                    {% endif %}

                    <div>
                        <table class="table table-hover align-middle">
                            <thead>
                                <tr>
                                    <th style="width: 18%;">{{ __('Target Type', plugin) }}</th>
                                    <th style="width: 18%;">{{ __('GLPI Target Field', plugin) }}</th>
                                    <th style="width: 25%;">{{ __('SAML Response Claim Key', plugin) }}</th>
                                    <th style="width: 18%;">{{ __('Default Fallback Value', plugin) }}</th>
                                    <th class="text-center" style="width: 8%;">{{ __('Required', plugin) }}</th>
                                    <th>{{ __('Status', plugin) }}</th>
                                    <th style="width: 8%;"></th>
                                </tr>
                            </thead>
                            <tbody id="claim_mapping_tbody">
                                {% for index, mapping in claim_mappings %}
                                    {% set is_system_required = (mapping.target_type == 'user_field' and (mapping.glpi_field == 'username' or mapping.glpi_field == 'email')) %}
                                    {% set is_username_locked = (mapping.target_type == 'user_field' and mapping.glpi_field == 'username') %}
                                    <tr class="claim-mapping-row" data-index="{{ index }}">
                                        <td>
                                            {% if is_system_required %}
                                                <input type="hidden" name="claim_map[{{ index }}][target_type]" value="{{ mapping.target_type }}">
                                            {% endif %}
                                            <select name="claim_map[{{ index }}][target_type]" class="form-select target-type-select" onchange="updateGlpiFields(this)" {% if is_system_required %}disabled{% endif %}>
                                                <option value="user_field" {% if mapping.target_type == 'user_field' %}selected{% endif %}>{{ __('User Field', plugin) }}</option>
                                                <option value="rule_field" {% if mapping.target_type == 'rule_field' %}selected{% endif %}>{{ __('Rule Field', plugin) }}</option>
                                            </select>
                                        </td>
                                        <td>
                                            {% if is_system_required %}
                                                <input type="hidden" name="claim_map[{{ index }}][glpi_field]" value="{{ mapping.glpi_field }}">
                                            {% endif %}
                                            <select name="claim_map[{{ index }}][glpi_field]" class="form-select glpi-field-select" {% if is_system_required %}disabled{% endif %}>
                                                {% if mapping.target_type == 'rule_field' %}
                                                    {% for field in allowed_rule_fields %}
                                                        <option value="{{ field }}" {% if mapping.glpi_field == field %}selected{% endif %}>{{ field|title }}</option>
                                                    {% endfor %}
                                                {% else %}
                                                    {% for field in allowed_user_fields %}
                                                        <option value="{{ field }}" {% if mapping.glpi_field == field %}selected{% endif %}>{{ field|title }}</option>
                                                    {% endfor %}
                                                {% endif %}
                                            </select>
                                        </td>
                                        <td>
                                            {% if is_username_locked %}
                                                <input type="hidden" name="claim_map[{{ index }}][saml_claim]" value="NameId">
                                            {% endif %}
                                            <div class="input-group">
                                                <input type="text" name="claim_map[{{ index }}][saml_claim]" value="{{ is_username_locked ? 'NameId' : mapping.saml_claim }}" class="form-control saml-claim-input" oninput="checkObserved(this)" {% if is_username_locked %}disabled{% else %}list="observed_claims_list"{% endif %}>
                                                {% if not is_username_locked and observed_claims is not empty %}
                                                    <button class="btn btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" data-bs-boundary="viewport" aria-expanded="false"></button>
                                                    <ul class="dropdown-menu dropdown-menu-end" style="max-height: 200px; overflow-y: auto;">
                                                        {% for claim in observed_claims %}
                                                            <li><a class="dropdown-item" href="#" onclick="selectClaim(this, '{{ claim|escape('js') }}'); return false;">{{ claim }}</a></li>
                                                        {% endfor %}
                                                    </ul>
                                                {% endif %}
                                            </div>
                                        </td>
                                        <td>
                                            <input type="text" name="claim_map[{{ index }}][default_value]" value="{{ mapping.default_value }}" class="form-control">
                                        </td>
                                        <td class="text-center">
                                            {% if is_system_required %}
                                                <input type="hidden" name="claim_map[{{ index }}][is_required]" value="1">
                                            {% endif %}
                                            <input type="checkbox" name="claim_map[{{ index }}][is_required]" value="1" class="form-check-input" {% if is_system_required or mapping.is_required == 1 %}checked{% endif %} {% if is_system_required %}disabled{% endif %}>
                                        </td>
                                        <td>
                                            <div class="status-indicators d-flex align-items-center gap-2">
                                                {% if is_username_locked or mapping.saml_claim in observed_claims %}
                                                    <span class="badge bg-success observed-badge">✅ {{ __('Observed', plugin) }}</span>
                                                {% elseif mapping.saml_claim is not empty %}
                                                    <span class="badge bg-warning unobserved-badge">⚠️ {{ __('Unobserved', plugin) }}</span>
                                                {% endif %}
                                                {% if mapping.target_type == 'rule_field' and mapping.glpi_field in unused_rule_fields %}
                                                    <span class="badge bg-danger unused-rule-badge" title="{{ __('This JIT criteria has no active rules in GLPI evaluating it.', plugin) }}">⚠️ {{ __('Unused in Rules', plugin) }}</span>
                                                {% endif %}
                                            </div>
                                        </td>
                                        <td>
                                            {% if not is_system_required %}
                                                <button type="button" class="btn btn-outline-danger btn-sm" onclick="deleteRow(this)">
                                                    <i class="fas fa-trash"></i> {{ __('Delete', plugin) }}
                                                </button>
                                            {% endif %}
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>

                    <div class="mb-4">
                        <button type="button" class="btn btn-primary" onclick="addRow('', '', '', '', 0)">
                            <i class="fas fa-plus"></i> {{ __('Add Mapping', plugin) }}
                        </button>
                    </div>



                    {% if claim_mappings is empty %}
                        <script>
                            $(function() {
                                addRow('user_field', 'username', 'NameId', '', 1);
                                addRow('user_field', 'email', 'http://schemas.xmlsoap.org/ws/2005/05/identity/claims/emailaddress', '', 1);
                                
                                const rawXml = {{ saml_xml_structure|json_encode|raw }};
                                const codeElem = document.getElementById('xml_highlighted_code');
                                if (codeElem && rawXml) {
                                    codeElem.innerHTML = highlightXml(rawXml);
                                }
                            });
                        </script>
                    {% else %}
                        <script>
                            $(function() {
                                rowCounter = {{ claim_mappings|length }};
                                
                                const rawXml = {{ saml_xml_structure|json_encode|raw }};
                                const codeElem = document.getElementById('xml_highlighted_code');
                                if (codeElem && rawXml) {
                                    codeElem.innerHTML = highlightXml(rawXml);
                                }
                            });
                        </script>
                    {% endif %}
                </div>
            </div>
            </div>
            <!-- ################################################################################-->
            <!-- Logging details -->
            <div class="tab-pane fade d-none" id="logging" role="tabpanel" aria-labelledby="logging-tab">
                <style>
                    /* Styling for custom logging tab */
                    .logging-badge {
                        display: inline-flex;
                        align-items: center;
                        justify-content: center;
                        padding: 0.25em 0.6em;
                        font-size: 0.75rem;
                        font-weight: 600;
                        line-height: 1;
                        text-align: center;
                        white-space: nowrap;
                        vertical-align: baseline;
                        border-radius: 0.375rem;
                        border: 1px solid transparent;
                    }
                    .logging-badge-success {
                        background-color: hsl(142, 70%, 95%);
                        color: hsl(142, 76%, 28%);
                        border-color: hsl(142, 70%, 90%);
                    }
                    .logging-badge-danger {
                        background-color: hsl(354, 70%, 96%);
                        color: hsl(354, 76%, 35%);
                        border-color: hsl(354, 70%, 90%);
                    }
                    /* Phase Badges HSL curated palette */
                    .logging-badge-phase-1 { /* Initial */
                        background-color: hsl(210, 80%, 96%);
                        color: hsl(210, 80%, 35%);
                        border-color: hsl(210, 80%, 90%);
                    }
                    .logging-badge-phase-2 { /* SAML ACS Expected */
                        background-color: hsl(35, 90%, 96%);
                        color: hsl(35, 90%, 35%);
                        border-color: hsl(35, 90%, 90%);
                    }
                    .logging-badge-phase-3 { /* SAML Authed */
                        background-color: hsl(190, 80%, 95%);
                        color: hsl(190, 80%, 30%);
                        border-color: hsl(190, 80%, 90%);
                    }
                    .logging-badge-phase-4 { /* GLPI Authed */
                        background-color: hsl(150, 60%, 95%);
                        color: hsl(150, 60%, 30%);
                        border-color: hsl(150, 60%, 90%);
                    }
                    .logging-badge-phase-5 { /* Reserved */
                        background-color: hsl(260, 30%, 95%);
                        color: hsl(260, 30%, 45%);
                        border-color: hsl(260, 30%, 90%);
                    }
                    .logging-badge-phase-6 { /* Forced Logoff */
                        background-color: hsl(10, 85%, 96%);
                        color: hsl(10, 85%, 40%);
                        border-color: hsl(10, 85%, 90%);
                    }
                    .logging-badge-phase-7 { /* Timed Out */
                        background-color: hsl(0, 0%, 90%);
                        color: hsl(0, 0%, 35%);
                        border-color: hsl(0, 0%, 80%);
                    }
                    .logging-badge-phase-8 { /* Logged Out */
                        background-color: hsl(280, 50%, 95%);
                        color: hsl(280, 50%, 40%);
                        border-color: hsl(280, 50%, 90%);
                    }
                    
                    .logging-table th {
                        font-weight: 600;
                        font-size: 0.8rem;
                        text-transform: uppercase;
                        letter-spacing: 0.05em;
                        color: var(--tb-secondary, #626976);
                    }
                    
                    .logging-table td {
                        padding: 0.65rem 0.5rem;
                    }
                    
                    /* Popover improvements */
                    .popover {
                        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
                        border-color: var(--tb-border-color, #dee2e6) !important;
                        border-radius: 0.5rem !important;
                        max-width: 480px !important;
                    }
                    .popover-header {
                        font-weight: 600;
                        background-color: var(--tb-light, #f8f9fa);
                        border-bottom-color: var(--tb-border-color, #dee2e6);
                    }
                </style>

                <div class="card-body">
                    <div class="d-flex flex-column gap-3">
                        <!-- Header with description -->
                        <div class="logging-header p-3 mb-2 rounded-3 border" style="background-color: var(--tb-light, #f8f9fa); border-color: var(--tb-border-color, #dee2e6);">
                            <h4 class="mb-2 text-primary d-flex align-items-center gap-2">
                                <i class="ti ti-history"></i>
                                {{ __("SAML SSO Authentication Logs", plugin) }}
                            </h4>
                            <p class="mb-0 text-muted fs-7">
                                {{ __("Track login phases, active sessions, assertion validations, and flow outcomes for troubleshooting.", plugin) }}
                            </p>
                        </div>

                        <!-- Search and filter toolbar -->
                        <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 p-2 rounded-2 border mb-3" style="background-color: rgba(0, 0, 0, 0.02);">
                            <div class="d-flex align-items-center gap-2 flex-grow-1" style="max-width: 500px;">
                                <div class="input-group">
                                    <span class="input-group-text bg-transparent border-end-0">
                                        <i class="ti ti-search text-muted"></i>
                                    </span>
                                    <input type="text" id="logging-search-input" class="form-control border-start-0" 
                                           placeholder="{{ __('Search username, session ID, location, or ID...', plugin) }}" 
                                           value="{{ logging_search }}">
                                    {% if logging_search is not empty %}
                                        <button type="button" class="btn btn-outline-secondary border-start-0 border-end-0" onclick="clearLoggingSearch()">
                                            <i class="ti ti-x"></i>
                                        </button>
                                    {% endif %}
                                    <button type="button" class="btn btn-primary" onclick="performLoggingSearch()">
                                        {{ __("Search", plugin) }}
                                    </button>
                                </div>
                            </div>
                            <div class="text-muted fs-7">
                                {{ __('Total records found: %s', plugin)|format('<strong>' ~ logging_total_count ~ '</strong>')|raw }}
                            </div>
                        </div>

                        <!-- Log entries table -->
                        <div class="table-responsive rounded-2 border">
                            <table class="table table-hover align-middle mb-0 logging-table">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width: 70px;">{{ __("ID", plugin) }}</th>
                                        <th style="width: 80px;">{{ __("IdP ID", plugin) }}</th>
                                        <th>{{ __("Username", plugin) }}</th>
                                        <th style="width: 110px;" class="text-center">{{ __("GLPI Authed", plugin) }}</th>
                                        <th style="width: 110px;" class="text-center">{{ __("SAML Authed", plugin) }}</th>
                                        <th>{{ __("Phase", plugin) }}</th>
                                        <th>{{ __("Login Time", plugin) }}</th>
                                        <th>{{ __("Last Click", plugin) }}</th>
                                        <th style="width: 90px;" class="text-center">{{ __("Location", plugin) }}</th>
                                        <th style="width: 90px;" class="text-center">{{ __("Trace", plugin) }}</th>
                                        <th style="width: 160px;" class="text-center">{{ __("Actions", plugin) }}</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% if loggingfields is empty %}
                                        <tr>
                                            <td colspan="11" class="text-center py-4 text-muted">
                                                <i class="ti ti-database-x fs-1 d-block mb-2"></i>
                                                {{ __("No logs match the criteria.", plugin) }}
                                            </td>
                                        </tr>
                                    {% else %}
                                        {% for logrow in loggingfields %}
                                            <tr>
                                                <td class="font-monospace text-muted">{{ logrow.id }}</td>
                                                <td>
                                                    <span class="badge bg-secondary-lt font-monospace px-2 py-1">{{ logrow.idpId }}</span>
                                                </td>
                                                <td>
                                                    <div class="d-flex align-items-center gap-2">
                                                        {% if logrow.avatarUrl is not empty %}
                                                            <span class="avatar avatar-xs rounded-circle" style="background-image: url({{ logrow.avatarUrl }})"></span>
                                                        {% else %}
                                                            <span class="avatar avatar-xs rounded-circle bg-blue-lt">
                                                                {{ logrow.userName|slice(0, 2)|upper }}
                                                            </span>
                                                        {% endif %}
                                                        <div>
                                                            <div class="font-weight-medium">
                                                                {{ logrow.userName }}
                                                                {% if logrow.clientCountry is not empty and logrow.clientCountry != '??' and logrow.clientCountry|upper != 'ZZ' %}
                                                                    <span class="ms-1" style="cursor: help;" data-bs-toggle="tooltip" title="{{ logrow.clientCountryName }} ({{ logrow.clientIp }})">
                                                                        <img src="https://flagcdn.com/16x12/{{ logrow.clientCountry|lower }}.png" width="16" height="12" alt="{{ logrow.clientCountry }}" style="vertical-align: middle; margin-top: -2px;">
                                                                    </span>
                                                                {% endif %}
                                                            </div>
                                                            <div class="text-muted fs-8 font-monospace" style="max-width: 150px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" data-bs-toggle="tooltip" title="Session ID: {{ logrow.sessionId }}">
                                                                {{ logrow.sessionId }}
                                                            </div>
                                                        </div>
                                                    </div>
                                                </td>
                                                <td class="text-center">
                                                    {% if logrow.glpiAuthed == 1 %}
                                                        <span class="logging-badge logging-badge-success">{{ __("Yes", plugin) }}</span>
                                                    {% else %}
                                                        <span class="logging-badge logging-badge-danger">{{ __("No", plugin) }}</span>
                                                    {% endif %}
                                                </td>
                                                <td class="text-center">
                                                    {% if logrow.samlAuthed == 1 %}
                                                        <span class="logging-badge logging-badge-success">{{ __("Yes", plugin) }}</span>
                                                    {% else %}
                                                        <span class="logging-badge logging-badge-danger">{{ __("No", plugin) }}</span>
                                                    {% endif %}
                                                </td>
                                                <td>
                                                    {% if logrow.phase == 1 %}
                                                        <span class="logging-badge logging-badge-phase-1" title="{{ __('Phase 1: Initial visit', plugin) }}">{{ __("Initial", plugin) }}</span>
                                                    {% elseif logrow.phase == 2 %}
                                                        <span class="logging-badge logging-badge-phase-2" 
                                                              data-bs-toggle="popover" data-bs-placement="top" data-bs-html="true" 
                                                              data-bs-content="{{ __("The identity provider was contacted, but GLPI didn't receive a successful response back at the ACS endpoint.<br><br><b>Common Solutions:</b><br>&bull; Verify the <strong>Reply URL</strong> in IdP matches the plugin setting <code>AcsUrl</code> exactly.<br>&bull; If using a reverse proxy, ensure the plugin setting <code>REQUESTS PROXIED</code> is enabled to trust <strong>X-Forwarded-Proto</strong> headers.<br>&bull; Check if the user closed the browser during login.", plugin)|e('html_attr') }}" 
                                                              title="{{ __('Phase 2: SAML ACS Expected', plugin) }}"
                                                              style="cursor: help;">
                                                            {{ __("SAML ACS Expected", plugin) }}
                                                        </span>
                                                    {% elseif logrow.phase == 3 %}
                                                        <span class="logging-badge logging-badge-phase-3" title="{{ __('Phase 3: Performed SAML IDP authentication', plugin) }}">{{ __("SAML Authed", plugin) }}</span>
                                                    {% elseif logrow.phase == 4 %}
                                                        <span class="logging-badge logging-badge-phase-4" title="{{ __('Phase 4: Performed GLPI session authentication', plugin) }}">{{ __("GLPI Authed", plugin) }}</span>
                                                    {% elseif logrow.phase == 5 %}
                                                        <span class="logging-badge logging-badge-phase-5" title="{{ __('Phase 5: File Exclude / Reserved', plugin) }}">{{ __("Reserved", plugin) }}</span>
                                                    {% elseif logrow.phase == 6 %}
                                                        <span class="logging-badge logging-badge-phase-6" title="{{ __('Phase 6: Session forced logged off', plugin) }}">{{ __("Forced Logoff", plugin) }}</span>
                                                    {% elseif logrow.phase == 7 %}
                                                        <span class="logging-badge logging-badge-phase-7" title="{{ __('Phase 7: Session Timed out', plugin) }}">{{ __("Timed Out", plugin) }}</span>
                                                    {% elseif logrow.phase == 8 %}
                                                        <span class="logging-badge logging-badge-phase-8" title="{{ __('Phase 8: Session Logged Out', plugin) }}">{{ __("Logged Out", plugin) }}</span>
                                                    {% else %}
                                                        <span class="logging-badge bg-light text-dark">{{ logrow.phase }}</span>
                                                    {% endif %}
                                                </td>
                                                <td class="text-nowrap fs-7 text-muted">{{ logrow.loginTime }}</td>
                                                <td class="text-nowrap fs-7 text-muted">{{ logrow.lastClickTime }}</td>
                                                <td class="text-center">
                                                    {% if logrow.location is not empty %}
                                                        <button type="button" class="btn btn-sm btn-ghost-secondary p-1 border-0" 
                                                                data-bs-toggle="popover" data-bs-placement="top" data-bs-html="true" 
                                                                data-bs-content="<pre class='p-2 mb-0 font-monospace text-wrap' style='max-height: 250px; overflow-y: auto; word-break: break-all;'>{{ logrow.location }}</pre>" 
                                                                title="{{ __('Location URL', plugin) }}">
                                                            <i class="ti ti-map-pin fs-4 text-info"></i>
                                                        </button>
                                                    {% else %}
                                                        <span class="text-muted fs-7">-</span>
                                                    {% endif %}
                                                </td>
                                                <td class="text-center">
                                                    {% if logrow.loginFlowTrace is not empty %}
                                                        <button type="button" class="btn btn-sm btn-ghost-secondary p-1 border-0" 
                                                                data-bs-toggle="popover" data-bs-placement="top" data-bs-html="true" 
                                                                data-bs-content="<pre class='p-2 mb-0 font-monospace text-wrap text-start' style='max-height: 350px; overflow-y: auto; white-space: pre-wrap; font-size: 0.8rem;'>{{ logrow.loginFlowTrace }}</pre>" 
                                                                title="{{ __('Login Flow Trace', plugin) }}">
                                                            <i class="ti ti-terminal-2 fs-4 text-warning"></i>
                                                        </button>
                                                    {% else %}
                                                        <span class="text-muted fs-7">-</span>
                                                    {% endif %}
                                                </td>
                                                <td class="text-center text-nowrap">
                                                    {% if logrow.isUserActive == 1 and logrow.phase != 6 and logrow.phase != 8 %}
                                                        <button type="button" class="btn btn-sm btn-outline-danger d-inline-flex align-items-center gap-1" onclick="samlssoForceLogoff({{ logrow.id }}, {{ inputfields.id.value }})">
                                                            <i class="ti ti-user-off fs-4"></i>
                                                            {{ __("Force Logoff & Disable", plugin) }}
                                                        </button>
                                                    {% else %}
                                                        <span class="text-muted fs-7">-</span>
                                                    {% endif %}
                                                </td>
                                            </tr>
                                        {% endfor %}
                                    {% endif %}
                                </tbody>
                            </table>
                        </div>

                        <!-- Pagination controls -->
                        {% if logging_total_pages > 1 %}
                            {% set start_page = logging_page - 3 < 1 ? 1 : logging_page - 3 %}
                            {% set end_page = logging_page + 3 > logging_total_pages ? logging_total_pages : logging_page + 3 %}
                            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mt-2">
                                <div class="text-muted fs-7">
                                    {{ __('Showing page %1$s of %2$s', plugin)|format('<strong>' ~ logging_page ~ '</strong>', '<strong>' ~ logging_total_pages ~ '</strong>')|raw }}
                                </div>
                                <nav aria-label="Logging pagination">
                                    <ul class="pagination pagination-sm mb-0">
                                        <li class="page-item {% if logging_page <= 1 %}disabled{% endif %}">
                                            <a class="page-link" href="#" onclick="changeLoggingPage({{ logging_page - 1 }}); return false;">
                                                <i class="ti ti-chevron-left"></i>
                                            </a>
                                        </li>
                                        
                                        {% if start_page > 1 %}
                                            <li class="page-item">
                                                <a class="page-link" href="#" onclick="changeLoggingPage(1); return false;">1</a>
                                            </li>
                                            {% if start_page > 2 %}
                                                <li class="page-item disabled"><span class="page-link">...</span></li>
                                            {% endif %}
                                        {% endif %}
                                        
                                        {% for p in start_page..end_page %}
                                            <li class="page-item {% if p == logging_page %}active{% endif %}">
                                                <a class="page-link" href="#" onclick="changeLoggingPage({{ p }}); return false;">{{ p }}</a>
                                            </li>
                                        {% endfor %}
                                        
                                        {% if end_page < logging_total_pages %}
                                            {% if end_page < logging_total_pages - 1 %}
                                                <li class="page-item disabled"><span class="page-link">...</span></li>
                                            {% endif %}
                                            <li class="page-item">
                                                <a class="page-link" href="#" onclick="changeLoggingPage({{ logging_total_pages }}); return false;">{{ logging_total_pages }}</a>
                                            </li>
                                        {% endif %}
                                        
                                        <li class="page-item {% if logging_page >= logging_total_pages %}disabled{% endif %}">
                                            <a class="page-link" href="#" onclick="changeLoggingPage({{ logging_page + 1 }}); return false;">
                                                <i class="ti ti-chevron-right"></i>
                                            </a>
                                        </li>
                                    </ul>
                                </nav>
                            </div>
                        {% endif %}
                    </div>
                </div>

                <script>
                    function performLoggingSearch() {
                        var searchInput = document.getElementById('logging-search-input');
                        var searchValue = searchInput ? searchInput.value.trim() : '';
                        var currentUrl = new URL(window.location.href);
                        if (searchValue) {
                            currentUrl.searchParams.set('search', searchValue);
                        } else {
                            currentUrl.searchParams.delete('search');
                        }
                        currentUrl.searchParams.set('page', '1');
                        window.location.href = currentUrl.toString();
                    }

                    function clearLoggingSearch() {
                        var currentUrl = new URL(window.location.href);
                        currentUrl.searchParams.delete('search');
                        currentUrl.searchParams.set('page', '1');
                        window.location.href = currentUrl.toString();
                    }

                    function changeLoggingPage(pageNumber) {
                        var currentUrl = new URL(window.location.href);
                        currentUrl.searchParams.set('page', pageNumber);
                        window.location.href = currentUrl.toString();
                    }

                    $(function() {
                        var searchInput = document.getElementById('logging-search-input');
                        if (searchInput) {
                            searchInput.addEventListener('keypress', function(e) {
                                if (e.key === 'Enter') {
                                    e.preventDefault();
                                    performLoggingSearch();
                                }
                            });
                        }
                        
                        // Initialize popovers on logging tab specifically with auto-close when mouse is not near or tabs switch
                        var popoverTriggerList = [].slice.call(document.querySelectorAll('#logging [data-bs-toggle="popover"]'));
                        var activePopoverInstance = null;
                        var activePopoverEl = null;
                        var closeTimeout = null;

                        popoverTriggerList.map(function (popoverTriggerEl) {
                            var popoverInstance = new bootstrap.Popover(popoverTriggerEl, {
                                sanitize: false,
                                trigger: 'manual'
                            });

                            function showPopover() {
                                if (closeTimeout) {
                                    clearTimeout(closeTimeout);
                                }
                                if (activePopoverInstance && activePopoverInstance !== popoverInstance) {
                                    activePopoverInstance.hide();
                                }
                                popoverInstance.show();
                                activePopoverInstance = popoverInstance;
                                activePopoverEl = popoverTriggerEl;
                            }

                            function delayHidePopover() {
                                if (closeTimeout) {
                                    clearTimeout(closeTimeout);
                                }
                                closeTimeout = setTimeout(function() {
                                    // Check if trigger or popover itself is hovered before hiding
                                    var activePopover = document.querySelector('.popover');
                                    var isTriggerHovered = activePopoverEl && activePopoverEl.matches(':hover');
                                    var isPopoverHovered = activePopover && activePopover.matches(':hover');

                                    if (isTriggerHovered || isPopoverHovered) {
                                        return; // Keep popover open
                                    }

                                    popoverInstance.hide();
                                    if (activePopoverInstance === popoverInstance) {
                                        activePopoverInstance = null;
                                        activePopoverEl = null;
                                    }
                                }, 750);
                            }

                            popoverTriggerEl.addEventListener('mouseenter', showPopover);
                            popoverTriggerEl.addEventListener('mouseleave', delayHidePopover);
                            popoverTriggerEl.addEventListener('click', function(e) {
                                e.preventDefault();
                                if (activePopoverInstance === popoverInstance) {
                                    popoverInstance.hide();
                                    activePopoverInstance = null;
                                    activePopoverEl = null;
                                } else {
                                    showPopover();
                                }
                            });

                            return popoverInstance;
                        });

                        // Keep popover open if mouse is hovering over the popover itself
                        document.addEventListener('mouseover', function(e) {
                            var targetPopover = e.target.closest('.popover');
                            if (targetPopover && activePopoverInstance) {
                                if (closeTimeout) {
                                    clearTimeout(closeTimeout);
                                }
                            }
                        });

                        document.addEventListener('mouseout', function(e) {
                            var targetPopover = e.target.closest('.popover');
                            if (targetPopover && activePopoverInstance) {
                                // Ignore mouseout events if moving to an element within the same popover
                                if (e.relatedTarget && e.relatedTarget.closest('.popover') === targetPopover) {
                                    return;
                                }
                                if (closeTimeout) {
                                    clearTimeout(closeTimeout);
                                }
                                closeTimeout = setTimeout(function() {
                                    var activePopover = document.querySelector('.popover');
                                    var isTriggerHovered = activePopoverEl && activePopoverEl.matches(':hover');
                                    var isPopoverHovered = activePopover && activePopover.matches(':hover');

                                    if (isTriggerHovered || isPopoverHovered) {
                                        return; // Keep popover open
                                    }

                                    if (activePopoverInstance) {
                                        activePopoverInstance.hide();
                                        activePopoverInstance = null;
                                        activePopoverEl = null;
                                    }
                                }, 750);
                            }
                        });

                        // Hide all popovers when switching tabs or clicking elsewhere
                        document.querySelectorAll('.nav-link, [data-bs-toggle="tab"]').forEach(function(tabEl) {
                            tabEl.addEventListener('click', function() {
                                if (activePopoverInstance) {
                                    activePopoverInstance.hide();
                                    activePopoverInstance = null;
                                    activePopoverEl = null;
                                }
                            });
                        });

                        document.addEventListener('click', function(e) {
                            if (activePopoverInstance && activePopoverEl && !activePopoverEl.contains(e.target) && !e.target.closest('.popover')) {
                                activePopoverInstance.hide();
                                activePopoverInstance = null;
                                activePopoverEl = null;
                            }
                        });
                    });
                </script>
            </div>
        </div>
    </div>
    <div class="card itil-footer" style="margin-top:10px;">
        <div class="form-buttons col-lg d-flex ms-auto ms-lg-0 flex-row-reverse p-1 ">
            <div class="m-1">
                <button class="btn btn-primary " type="submit" name="update" title="{{ __('Save', plugin) }}">
                    <i class="far fa-save"></i>
                    <span class="d-none d-xl-block">{{ __("Save", plugin) }}</span>
                    </button>
            </div>
            <div class="m-1">
                <button class="btn btn-ghost-danger" type="submit" name="delete" title="" data-bs-toggle="tooltip" data-bs-placement="top" data-bs-original-title="{{ __('Put in trashbin', plugin) }}">
                    <i class="ti ti-trash"></i>
                    <span class="d-none d-xl-block">{{ __("Delete", plugin) }}</span>
                    </button>
            </div>
            {% if inputfields.debug.value == true %}
            <div class="m-1 align-middle text-muted pull-left pt-2">
                {{ __('⚠️ Warning SP metadata exposed! - ROWID: %1$s | CREATED DATE: %2$s | LAST UPDATED: %3$s', plugin)|format(inputfields.id.value, inputfields.date_creation.value|formatted_datetime, inputfields.date_mod.value|formatted_datetime) }}
            {% endif %}
        </div>
    </div>
</div>
{{ close_form|raw }}

<!-- Standalone form for Force Logoff & Disable to prevent nested form submissions -->
<form id="samlsso-forcelogoff-form" action="{{ glpi_rootdoc }}" method="POST" style="display:none;">
    <input type="hidden" name="_glpi_csrf_token" value="{{ csrf_token }}">
    <input type="hidden" name="action" value="forcelogoff">
    <input type="hidden" name="state_id" id="samlsso-forcelogoff-state-id" value="">
    <input type="hidden" name="id" id="samlsso-forcelogoff-config-id" value="">
</form>

<script>
function samlssoForceLogoff(stateId, configId) {
    if (confirm('{{ __("Are you sure you want to disable this user and force logoff?", plugin)|escape("js") }}')) {
        document.getElementById('samlsso-forcelogoff-state-id').value = stateId;
        document.getElementById('samlsso-forcelogoff-config-id').value = configId;
        document.getElementById('samlsso-forcelogoff-form').submit();
    }
}
</script>