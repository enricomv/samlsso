<!-- implemented in ConfigForm->generateForm() -->
<!-- https://codeberg.org/QuinQuies/glpisaml/issues/13 -->
{% import glpi_tpl_macro as fields %}

<script>
    // Remember tab state
    $(function() {
        $('a[data-bs-toggle="tab"]').on('shown.bs.tab', function (e) {
            localStorage.setItem('lastTab', $(this).attr('href'));
        });
        var lastTab = localStorage.getItem('lastTab');
        
        var urlParams = new URLSearchParams(window.location.search);
        if (urlParams.has('search') || urlParams.has('page')) {
            lastTab = '#logging';
        }
        
        if (lastTab) {
            $('[href="' + lastTab + '"]').tab('show');
        }
    });

    // Get user id and username
    const currentUserId = {{ currentUserId|json_encode|raw }};
    const currentUsername = {{ currentUsername|json_encode|raw }};
    
    var mappingPresets = {{ mapping_presets|json_encode|raw }};
    const allowedUserFields = {{ allowed_user_fields|json_encode|raw }};
    const allowedRuleFields = {{ allowed_rule_fields|json_encode|raw }};
    const observedClaims = {{ observed_claims|json_encode|raw }};

    function applyPreset(presetName) {
        if (!presetName || !mappingPresets[presetName]) {
            return;
        }
        var preset = mappingPresets[presetName];
        var tbody = document.getElementById('claim_mapping_tbody');
        tbody.innerHTML = '';
        rowCounter = 0;

        // username always remains NameId and is added manually
        addRow('user_field', 'username', 'NameId', '', 1);

        for (var field in preset) {
            if (field === 'username') {
                continue; // Skip updating username mapping
            }
            var targetType = (field === 'groups') ? 'rule_field' : 'user_field';
            addRow(targetType, field, preset[field], '', (field === 'email') ? 1 : 0);
        }
        document.getElementById('preset_selector').value = '';
    }

    function updateGlpiFields(selectElem) {
        const row = selectElem.closest('tr');
        const glpiSelect = row.querySelector('.glpi-field-select');
        const targetType = selectElem.value;
        
        if (!targetType) {
            glpiSelect.innerHTML = '';
            glpiSelect.classList.add('d-none');
            return;
        }
        
        glpiSelect.innerHTML = '';
        const fields = targetType === 'rule_field' ? allowedRuleFields : allowedUserFields;
        
        fields.forEach(field => {
            const opt = document.createElement('option');
            opt.value = field;
            opt.textContent = field.charAt(0).toUpperCase() + field.slice(1);
            glpiSelect.appendChild(opt);
        });

        glpiSelect.classList.remove('d-none');

        const unusedBadge = row.querySelector('.unused-rule-badge');
        if (unusedBadge) {
            if (targetType !== 'rule_field') {
                unusedBadge.classList.add('d-none');
            } else {
                unusedBadge.classList.remove('d-none');
            }
        }
    }

    let rowCounter = 0;

    function addRow(targetType = '', glpiField = '', samlClaim = '', defaultValue = '', isRequired = 0) {
        const tbody = document.getElementById('claim_mapping_tbody');
        const index = rowCounter++;
        
        const tr = document.createElement('tr');
        tr.className = 'claim-mapping-row';
        tr.setAttribute('data-index', index);
        
        const fields = targetType === 'rule_field' ? allowedRuleFields : allowedUserFields;
        let glpiOptions = '';
        if (targetType) {
            fields.forEach(field => {
                const selected = field === glpiField ? 'selected' : '';
                glpiOptions += `<option value="${field}" ${selected}>${field.charAt(0).toUpperCase() + field.slice(1)}</option>`;
            });
        }

        const isObserved = observedClaims.includes(samlClaim);
        const isUsernameLocked = targetType === 'user_field' && glpiField === 'username';
        const isSystemRequired = targetType === 'user_field' && (glpiField === 'username' || glpiField === 'email');
        const disabledAttr = isSystemRequired ? 'disabled' : '';
        const checkedAttr = (isSystemRequired || isRequired) ? 'checked' : '';
        
        const hiddenInputs = `
            ${isSystemRequired ? `
                <input type="hidden" name="claim_map[${index}][target_type]" value="${targetType}">
                <input type="hidden" name="claim_map[${index}][glpi_field]" value="${glpiField}">
                <input type="hidden" name="claim_map[${index}][is_required]" value="1">
            ` : ''}
            ${isUsernameLocked ? `
                <input type="hidden" name="claim_map[${index}][saml_claim]" value="NameId">
            ` : ''}
        `;
        
        const deleteButton = isSystemRequired ? '' : `
            <button type="button" class="btn btn-outline-danger btn-sm" onclick="deleteRow(this)">
                <i class="fas fa-trash"></i> Delete
            </button>
        `;

        let dropdownHtml = '';
        if (!isUsernameLocked && observedClaims.length > 0) {
            dropdownHtml += `
                <button class="btn btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" data-bs-boundary="viewport" aria-expanded="false"></button>
                <ul class="dropdown-menu dropdown-menu-end" style="max-height: 200px; overflow-y: auto;">
            `;
            observedClaims.forEach(claim => {
                dropdownHtml += `<li><a class="dropdown-item" href="#" onclick="selectClaim(this, '${claim}'); return false;">${claim}</a></li>`;
            });
            dropdownHtml += `</ul>`;
        }
        
        tr.innerHTML = `
            <td>
                ${hiddenInputs}
                <select name="claim_map[${index}][target_type]" class="form-select target-type-select" onchange="updateGlpiFields(this)" ${disabledAttr}>
                    <option value="" ${targetType === '' ? 'selected' : ''}>-- Select Target Type --</option>
                    <option value="user_field" ${targetType === 'user_field' ? 'selected' : ''}>User Field</option>
                    <option value="rule_field" ${targetType === 'rule_field' ? 'selected' : ''}>Rule Field</option>
                </select>
            </td>
            <td>
                <select name="claim_map[${index}][glpi_field]" class="form-select glpi-field-select ${targetType === '' ? 'd-none' : ''}" ${disabledAttr}>
                    ${glpiOptions}
                </select>
            </td>
            <td>
                <div class="input-group">
                    <input type="text" name="claim_map[${index}][saml_claim]" value="${isUsernameLocked ? 'NameId' : samlClaim}" class="form-control saml-claim-input" oninput="checkObserved(this)" ${isUsernameLocked ? 'disabled' : 'list="observed_claims_list"'}>
                    ${dropdownHtml}
                </div>
            </td>
            <td>
                <input type="text" name="claim_map[${index}][default_value]" value="${defaultValue}" class="form-control">
            </td>
            <td class="text-center">
                <input type="checkbox" name="claim_map[${index}][is_required]" value="1" class="form-check-input" ${checkedAttr} ${disabledAttr}>
            </td>
            <td>
                <div class="status-indicators d-flex align-items-center gap-2">
                    <span class="badge bg-success observed-badge ${((isUsernameLocked || samlClaim) && (isUsernameLocked || isObserved)) ? '' : 'd-none'}">✅ Observed</span>
                    <span class="badge bg-warning unobserved-badge ${(!isUsernameLocked && samlClaim && !isObserved) ? '' : 'd-none'}">⚠️ Unobserved</span>
                </div>
            </td>
            <td>
                ${deleteButton}
            </td>
        `;
        
        tbody.appendChild(tr);
    }

    function selectClaim(linkElem, claimValue) {
        const input = linkElem.closest('.input-group').querySelector('.saml-claim-input');
        input.value = claimValue;
        checkObserved(input);
    }

    function checkObserved(inputElem) {
        const row = inputElem.closest('tr');
        const val = inputElem.value.trim();
        const observedBadge = row.querySelector('.observed-badge');
        const unobservedBadge = row.querySelector('.unobserved-badge');
        
        if (val === '') {
            observedBadge.classList.add('d-none');
            unobservedBadge.classList.add('d-none');
            return;
        }
        
        if (observedClaims.includes(val) || val === 'NameId') {
            observedBadge.classList.remove('d-none');
            unobservedBadge.classList.add('d-none');
        } else {
            observedBadge.classList.add('d-none');
            unobservedBadge.classList.remove('d-none');
        }
    }

    function deleteRow(btnElem) {
        btnElem.closest('tr').remove();
    }

    function highlightXml(xml) {
        if (!xml) return '';
        let escaped = xml
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;');

        // Highlight XML comments first so they don't get matched by tag highlights
        let comments = [];
        escaped = escaped.replace(/&lt;!--[\s\S]*?--&gt;/g, function(match) {
            comments.push(match);
            return '___COMMENT_PLACEHOLDER_' + (comments.length - 1) + '___';
        });

        // Highlight tags, attributes, and values
        escaped = escaped.replace(/(&lt;\/?[a-zA-Z0-9_:-]+)([\s\S]*?)((\/?&gt;)|(&gt;))/g, function(match, tagName, attrs, tagEnd) {
            let highlightedAttrs = attrs.replace(/([a-zA-Z0-9_:-]+)=("([^"]*)"|'([^']*)')/g, function(attrMatch, attrName, attrVal) {
                return ' <span class="xml-attr">' + attrName + '</span>=<span class="xml-val">' + attrVal + '</span>';
            });
            return '<span class="xml-tag">' + tagName + '</span>' + highlightedAttrs + '<span class="xml-tag">' + tagEnd + '</span>';
        });

        // Restore comments
        escaped = escaped.replace(/___COMMENT_PLACEHOLDER_(\d+)___/g, function(match, index) {
            return '<span class="xml-comment">' + comments[parseInt(index, 10)] + '</span>';
        });

        return escaped;
    }
</script>

<form name="form" method="post" action="{{ glpi_rootdoc }}" id="phpsaml_config">
<div class="phpsaml_config_wrapper" id="samlForm">
    <input type="hidden" name="{{ inputfields.id.field }}" value="{{ inputfields.id.value }}">

    <div class="card" style="min-height:100%;">
        <!-- Input fields -->
        <ul class="nav nav-tabs" id="samlTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <a class="nav-link active" 
                   id="general-tab" 
                   data-bs-toggle="tab" 
                   href="#general" 
                   data-bs-target="#general" 
                   type="button" role="tab" 
                   aria-controls="general" 
                   aria-selected="true"><b>{{ __("General") }} {{ general_warning }}</b></a>
            </li>
            <li class="nav-item" role="presentation">
                <a class="nav-link" 
                   id="general-tab" 
                   data-bs-toggle="tab" 
                   href="#transit" 
                   data-bs-target="#transit" 
                   type="button" 
                   role="tab" 
                   aria-controls="transit" 
                   aria-selected="true"><b>{{ __('Transit', plugin) }} {{ transit_warning }}</b></a>
            </li>
            <li class="nav-item" role="presentation">
                <a class="nav-link" 
                   id="provider-tab" 
                   data-bs-toggle="tab" 
                   href="#provider" 
                   data-bs-target="#provider" 
                   type="button" 
                   role="tab" 
                   aria-controls="provider" 
                   aria-selected="false"><b>{{ __('Service provider', plugin) }} {{ provider_warning }}</b></a>
            </li>
            <li class="nav-item" role="presentation">
                <a class="nav-link" 
                   id="idp-tab" 
                   data-bs-toggle="tab" 
                   href="#idp" 
                   data-bs-target="#idp" 
                   type="button" 
                   role="tab" 
                   aria-controls="idp" 
                   aria-selected="false"><b>{{ __('Identity provider', plugin) }} {{ idp_warning }}</b></a>
            </li>
            <li class="nav-item" role="presentation">
                <a class="nav-link" 
                   id="security-tab" 
                   data-bs-toggle="tab" 
                   href="#security" 
                   data-bs-target="#security" 
                   type="button" 
                   role="tab" 
                   aria-controls="security" 
                   aria-selected="false"><b>{{ __('Security') }} {{ security_warning }}</b></a>
            </li>
            <li class="nav-item" role="presentation">
                <a class="nav-link" 
                   id="claim-mapping-tab" 
                   data-bs-toggle="tab" 
                   href="#claim_mapping" 
                   data-bs-target="#claim_mapping" 
                   type="button" 
                   role="tab" 
                   aria-controls="claim_mapping" 
                   aria-selected="false"><b>{{ __('Claim Mapping', plugin) }} {{ claim_tab_warning }}</b></a>
            </li>
            <li class="nav-item" role="presentation">
                <a class="nav-link"
                   id="logging-tab" 
                   data-bs-toggle="tab" 
                   href="#logging" 
                   data-bs-target="#logging" 
                   type="button" 
                   role="tab" 
                   aria-controls="logging" 
                   aria-selected="false"><b>{{ __('Logging') }}</b></a>
            </li>
        </ul>
        <div class="tab-content flex-fill glpisaml" id="myTabContent">
           <!-- ################################################################################-->
            <!-- General details -->
            <div class="tab-pane fade show active" id="general" role="tabpanel" aria-labelledby="general-tab">
                <div class="card-body">
                    <div class="row g-2">
                        <!-- name field -->
                        <div>
                            {% set error_helper %}
                                {% if inputfields.name.errors == true %}
                                    <div id="textHelper" class="form-text" style="color:red;">{{ inputfields.name.errors }}</div>
                                {% endif %}
                                {% if buttonsHiddenWarn == true %}
                                    <div id="textHelper" class="form-text" style="color:rgb(180, 120, 8)">⚠️ Userdomain is configured. The login button will be hidden from the loginscreen. Clear the Userdomain to make the button visable again.</div>
                                {% endif %}
                            {% endset %}

                            {{ fields.textField(
                                inputfields.name.field, 
                                inputfields.name.value, 
                                inputfields.name.formtitle, 
                                {
                                    'add_field_html': error_helper,
                                    helper: inputfields.name.formexplain,
                                }
                            ) }}
                        </div>
                   
                        <!-- icon field -->
                        <div>
                            {% set error_helper %}
                                {% if inputfields.conf_icon.errors == true %}
                                    <div id="textHelper" class="form-text" style="color:red;">{{ inputfields.conf_icon.errors }}</div>
                                {% endif %}
                                {% if buttonsHiddenWarn == true %}
                                    <div id="textHelper" class="form-text" style="color:rgb(180, 120, 8)">⚠️ Userdomain is configured. The login button will be hidden from the loginscreen. Clear the Userdomain to make the button visable again.</div>
                                {% endif %}
                            {% endset %}
                            {{ fields.textField(
                                inputfields.conf_icon.field, 
                                inputfields.conf_icon.value, 
                                inputfields.conf_icon.formtitle, 
                                {
                                    'add_field_html': error_helper,
                                    helper: inputfields.conf_icon.formexplain,
                                }
                            ) }}
                        </div>

                        <!-- domain field -->
                        <div>
                            {% set error_helper %}
                                {% if inputfields.conf_domain.errors == true %}
                                    <div id="textHelper" class="form-text" style="color:red;">{{ inputfields.conf_domain.errors }}</div>
                                {% endif %}
                                {% if buttonsHiddenWarn == true %}
                                    <div id="textHelper" class="form-text" style="color:rgb(3, 126, 26)">🔒 Userdomain is configured. Users can trigger a Saml Login by providing their {username}@{userdomain} in the glpi username field and pressing the login button. The password field is ignored and can be left blank. This is a more secure option that wont expose configured IDPs.
                                    </div>
                                {% endif %}
                            {% endset %}

                            {{ fields.textField(
                                inputfields.conf_domain.field, 
                                inputfields.conf_domain.value, 
                                inputfields.conf_domain.formtitle, 
                                {
                                    'add_field_html': error_helper|raw,
                                    helper: inputfields.conf_domain.formexplain,
                                }
                            ) }}
                        </div>

                        <!-- Comment field -->
                        <div>
                            {% set error_helper %}
                                {% if inputfields.comment.errors == true %}
                                    <div id="textHelper" class="form-text" style="color:red;">{{ inputfields.comment.errors }}</div>
                                {% endif %}
                            {% endset %}
                            {{ fields.textareaField(
                                inputfields.comment.field, 
                                inputfields.comment.value, 
                                inputfields.comment.formtitle, 
                                {
                                    'required':false,
                                    'add_field_html': error_helper,
                                    helper: inputfields.comment.formexplain,
                                }
                            ) }}
                        </div>

                         <!-- enabled -->
                         <div>
                            {% set error_helper %}
                                {% if inputfields.is_active.errors == true %}
                                    <div id="textHelper" class="form-text" style="color:red;">{{ inputfields.is_active.errors }}</div>
                                {% endif %}
                            {% endset %}
                            {{ fields.sliderField(
                                inputfields.is_active.field,
                                inputfields.is_active.value,
                                inputfields.is_active.formtitle,
                               {
                                  'add_field_html': error_helper,
                                  helper: inputfields.is_active.formexplain,
                               }
                            ) }}
                        </div>

                        <!-- Debug mode -->
                        <div>
                            {% set error_helper %}
                                {% if inputfields.debug.errors == true %}
                                    <div id="textHelper" class="form-text" style="color:red;">{{ inputfields.debug.errors }}</div>
                                {% endif %}
                            {% endset %}
                            {{ fields.sliderField(
                                inputfields.debug.field,
                                inputfields.debug.value,
                                inputfields.debug.formtitle,
                               {
                                  'add_field_html': error_helper,
                                  helper: inputfields.debug.formexplain,
                               }
                            ) }}
                        </div>
                    </div>
                </div>
            </div>
            <!-- ################################################################################-->
            <!-- transit tab -->
            <div class="tab-pane fade show" id="transit" role="tabpanel" aria-labelledby="transit-tab">
                <div class="card-body">
                    <div class="row g-2">

                        <!-- compress_requests -->
                        <div>
                            {% set error_helper %}
                                {% if inputfields.compress_requests.errors == true %}
                                    <div id="textHelper" class="form-text" style="color:red;">{{ inputfields.compress_requests.errors }}</div>
                                {% endif %}
                            {% endset %}
                            {{ fields.sliderField(
                                inputfields.compress_requests.field,
                                inputfields.compress_requests.value,
                                inputfields.compress_requests.formtitle,
                               {
                                  'add_field_html': error_helper,
                                   helper: inputfields.compress_requests.formexplain,
                               }
                            ) }}
                        </div>

                        <!-- compress_responses -->
                        <div>
                            {% set error_helper %}
                                {% if inputfields.compress_responses.errors == true %}
                                    <div id="textHelper" class="form-text" style="color:red;">{{ inputfields.compress_responses.errors }}</div>
                                {% endif %}
                            {% endset %}
                            {{ fields.sliderField(
                                inputfields.compress_responses.field,
                                inputfields.compress_responses.value,
                                inputfields.compress_responses.formtitle,
                               {
                                  'add_field_html': error_helper,
                                   helper: inputfields.compress_responses.formexplain,
                               }
                            ) }}
                        </div>
                        
                        <!-- Proxied -->
                        <div>
                            {% set error_helper %}
                                {% if inputfields.proxied.errors == true %}
                                    <div id="textHelper" class="form-text" style="color:red;">{{ inputfields.proxied.errors }}</div>
                                {% endif %}
                                {% if inputfields.proxied.value == true %}
                                    {% if inputfields.strict.value == true %}
                                        <div id="textHelper" class="form-text" style="color:rgb(180, 120, 8);">⚠️ Beware, misaligned proxy schemes might break the samlValidation in strict mode.<br>(<b>https</b>://external)=>(<b>http</b>://internal)</div>
                                    {% endif %}
                                {% endif %}
                            {% endset %}
                            {{ fields.sliderField(
                                inputfields.proxied.field,
                                inputfields.proxied.value,
                                inputfields.proxied.formtitle,
                               {
                                  'add_field_html': error_helper,
                                   helper: inputfields.proxied.formexplain,
                               }
                            ) }}
                        </div>

                        <!-- validate_xml -->
                        <div>
                            {% set error_helper %}
                                {% if inputfields.validate_xml.errors == true %}
                                    <div id="textHelper" class="form-text" style="color:red;">{{ inputfields.validate_xml.errors }}</div>
                                {% endif %}
                                {% if inputfields.strict.value == false %}
                                    <div id="textHelper" class="form-text" style="color:rgb(180, 120, 8);">⚠️ Strict is disabled, validate xml setting will not do anything.</div>
                                {% endif %}
                            {% endset %}
                            {{ fields.sliderField(
                                inputfields.validate_xml.field,
                                inputfields.validate_xml.value,
                                inputfields.validate_xml.formtitle,
                               {
                                  'add_field_html': error_helper,
                                   helper: inputfields.validate_xml.formexplain,
                               }
                            ) }}
                        </div>

                        <!-- validate_destination -->
                        <div>
                            {% set error_helper %}
                                {% if inputfields.validate_destination.errors == true %}
                                    <div id="textHelper" class="form-text" style="color:red;">{{ inputfields.validate_destination.errors }}</div>
                                {% endif %}
                            {% endset %}
                            {{ fields.sliderField(
                                inputfields.validate_destination.field,
                                inputfields.validate_destination.value,
                                inputfields.validate_destination.formtitle,
                               {
                                  'add_field_html': error_helper,
                                   helper: inputfields.validate_destination.formexplain,
                               }
                            ) }}
                        </div>

                        <!-- lowercase_url_encoding -->
                        <div>
                            {% set error_helper %}
                                {% if inputfields.lowercase_url_encoding.errors == true %}
                                    <div id="textHelper" class="form-text" style="color:red;">{{ inputfields.lowercase_url_encoding.errors }}</div>
                                {% endif %}
                            {% endset %}
                            {{ fields.sliderField(
                                inputfields.lowercase_url_encoding.field,
                                inputfields.lowercase_url_encoding.value,
                                inputfields.lowercase_url_encoding.formtitle,
                               {
                                  'add_field_html': error_helper,
                                   helper: inputfields.lowercase_url_encoding.formexplain,
                               }
                            ) }}
                        </div>

                    </div>
                </div>
            </div>

            <!-- ################################################################################-->
            <div class="tab-pane fade" id="provider" role="tabpanel" aria-labelledby="provider-tab">
                <div class="card-body">

                    <!-- Service provider details -->
                    <div>
                        <!-- Entity ID -->
                        {{ fields.textField(
                            'EntityID', 
                            entityID, 
                            'Entity ID',
                            {
                                'id': 'EntityId',
                                'readonly':true,
                                'is_copyable': true,
                                helper: __('You need to configure the Entity ID at the identity provider. This value is
                                            crosschecked by the identity provider to make sure the sign-in request is
                                            originating from the correct service provider.'),
                            }
                        ) }}

                        <!-- Meta URL -->
                        {% set metaUrl %}
                            <div class="btn-group btn-group-sm d-flex">
                                <input type="text" id="MetaUrl" class="form-control rounded-end-0" name="MetaUrl" value="{{ metaUrl }}" readonly="readonly">
                                {% if inputfields.debug.value == false %}
                                    {% set rand = random() %}
                                    <button type="button" id="meta_warning_{{ rand }}" class="btn btn-outline-secondary">
                                        <i class="ti ti-alert-triangle"></i>
                                    </button>
                                    {% do call('Html::showToolTip', [
                                        "Debug is disabled, metadata will only be exposed if 'debug' is enabled.",
                                        {'applyto': 'meta_warning_' ~ rand}
                                    ]) %}
                                {% endif %}
                                <button type="button" class="btn btn-outline-secondary" onclick="copyDisclosablePasswordFieldToClipboard('MetaUrl')">
                                    <i class="ti ti-clipboard-copy disclose"></i>
                                </button>
                            </div>
                        {% endset %}
                        {{ fields.field(
                            'MetaUrl', 
                            metaUrl, 
                            'MetaUrl',
                            {
                                helper: __('The location of the metadata provider for this service provider (GLPI). The meta location can be
                                            used by the identity provider to collect important information from this service provider like
                                            what public certificate to use for signing and encrypting the SamlResponse.'),
                            }
                        ) }}
                       
                        <!-- ACS url -->
                        {{ fields.textField(
                            'AcsUrl', 
                            acsUrl, 
                            'AcsUrl',
                            {
                                'id': 'AcsUrl',
                                'readonly':true,
                                'is_copyable': true,
                                helper: __('The location of the Assertion Consumer Service (ACS) for this service provider (GLPI). 
                                            This url is called by the identity provider after succesfull login.'),
                            }
                        ) }}


                        <!-- Logout url -->
                        {{ fields.textField(
                            'SloUrl', 
                             sloUrl, 
                            'SloUrl',
                            {
                                'id': 'SloUrl',
                                'readonly':true,
                                'is_copyable': true,
                                helper: __('The location where logout requests should be send back to from the Identity Provider.'),
                            }
                        ) }}
                    </div>

                    <!-- sp_certificate -->
                    <div>
                        {% set error_helper %}
                            {% if inputfields.sp_private_key.errors == true %}
                                <div id="textHelper" class="form-text" style="color:red;">{{ inputfields.sp_private_key.errors }}</div>
                            {% endif %}
                            {% if inputfields.sp_certificate.errors == true %}
