            <!-- Claim Mapping details -->
            <div class="tab-pane fade" id="claim_mapping" role="tabpanel" aria-labelledby="claim-mapping-tab">
                <style>
                    #xml_highlighted_code { color: #24292e; }
                    .xml-tag { color: #d73a49; font-weight: bold; }
                    .xml-attr { color: #6f42c1; }
                    .xml-val { color: #032f62; }
                    .xml-comment { color: #6a737d; font-style: italic; }
                </style>
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="card-title mb-0">{{ __('SAML Claim Mapping', plugin) }}</h5>
                        <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-toggle="collapse" data-bs-target="#samlsso-mapping-tools-collapse" aria-expanded="false" aria-controls="samlsso-mapping-tools-collapse">
                            <i class="fas fa-tools me-1"></i>{{ __('Mapping Tools', plugin) }}
                        </button>
                    </div>

                    <!-- Collapsible Mapping Tools Panel -->
                    <div class="collapse mb-4" id="samlsso-mapping-tools-collapse">
                        <div class="card card-body bg-light border-0 shadow-sm p-3">
                            <h6 class="fw-bold mb-2 text-dark"><i class="fas fa-info-circle me-1"></i>{{ __('Mapping Assistant', plugin) }}</h6>
                            <p class="text-muted mb-3" style="font-size: 0.85rem;">
                                {{ __('Map SAML response claim keys dynamically either directly to user profile fields or as JIT Rule criteria. Configure defaults and required verification checks.', plugin) }}
                            </p>

                            <!-- Preset selection and XML toggle -->
                            <div class="row align-items-center g-3">
                                <div class="col-md-7">
                                    <div class="d-flex align-items-center">
                                        <label class="mb-0 me-3 fw-bold" style="white-space: nowrap;">{{ __('Apply Preset', plugin) }}</label>
                                        <select id="preset_selector" class="form-select form-select-sm" onchange="applyPreset(this.value)">
                                            <option value="">-- {{ __('Select Preset', plugin) }} --</option>
                                            {% for name, preset in mapping_presets %}
                                                <option value="{{ name }}">{{ name|title }}</option>
                                            {% endfor %}
                                        </select>
                                    </div>
                                </div>
                                <div class="col-md-5 text-end">
                                    <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-toggle="collapse" data-bs-target="#samlsso-xml-collapse" aria-expanded="false" aria-controls="samlsso-xml-collapse">
                                        <i class="fas fa-code me-1"></i>{{ __('View observed samlResponse XML', plugin) }}
                                    </button>
                                </div>
                            </div>

                            <!-- Collapsible SAML Response XML structure inside the assistant -->
                            <div class="collapse mt-3" id="samlsso-xml-collapse">
                                <div class="border rounded bg-white p-3">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <span class="fw-bold text-muted small"><i class="fas fa-code"></i> {{ __('Sanitized SAML Response XML Structure', plugin) }}</span>
                                    </div>
                                    {% if saml_xml_structure is not empty %}
                                        <div class="alert alert-info py-2 px-3 mb-2 small">
                                            <i class="fas fa-info-circle text-primary me-1"></i>{{ __('This shows the structure of the last received SAML Response. Cryptographic keys, signatures, digests, and PII text node values have been stripped.', plugin) }}
                                        </div>
                                        <pre class="bg-light p-3 border rounded font-monospace mb-0" style="max-height: 450px; overflow-y: auto;"><code id="xml_highlighted_code"></code></pre>
                                    {% else %}
                                        <p class="text-muted mb-0 small"><i class="fas fa-info-circle"></i> {{ __('No SAML response has been recorded yet. Perform a successful login to populate this view.', plugin) }}</p>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </div>

                    <hr>

                    <datalist id="observed_claims_list">
                        {% for claim in observed_claims %}
                            <option value="{{ claim }}"></option>
                        {% endfor %}
                    </datalist>

                    <!-- Dynamic Mapping Grid -->
                    {% if claim_errors is not empty %}
                        <div class="alert alert-danger mb-4">
                            <h5 class="alert-heading"><i class="fas fa-exclamation-triangle me-2"></i>{{ __('Claim Mapping Validation Errors', plugin) }}</h5>
                            <ul class="mb-0">
                                {% for key, err in claim_errors %}
                                    <li>{{ err }}</li>
                                {% endfor %}
                            </ul>
                        </div>
                    {% endif %}

                    <div>
                        <table class="table table-hover align-middle">
                            <thead>
                                <tr>
                                    <th style="width: 18%;">{{ __('Target Type', plugin) }}</th>
                                    <th style="width: 18%;">{{ __('GLPI Target Field', plugin) }}</th>
                                    <th style="width: 25%;">{{ __('SAML Response Claim Key', plugin) }}</th>
                                    <th style="width: 18%;">{{ __('Default Fallback Value', plugin) }}</th>
                                    <th class="text-center" style="width: 8%;">{{ __('Required', plugin) }}</th>
                                    <th>{{ __('Status', plugin) }}</th>
                                    <th style="width: 8%;"></th>
                                </tr>
                            </thead>
                            <tbody id="claim_mapping_tbody">
                                {% for index, mapping in claim_mappings %}
                                    {% set is_system_required = (mapping.target_type == 'user_field' and (mapping.glpi_field == 'username' or mapping.glpi_field == 'email')) %}
                                    {% set is_username_locked = (mapping.target_type == 'user_field' and mapping.glpi_field == 'username') %}
                                    <tr class="claim-mapping-row" data-index="{{ index }}">
                                        <td>
                                            {% if is_system_required %}
                                                <input type="hidden" name="claim_map[{{ index }}][target_type]" value="{{ mapping.target_type }}">
                                            {% endif %}
                                            <select name="claim_map[{{ index }}][target_type]" class="form-select target-type-select" onchange="updateGlpiFields(this)" {% if is_system_required %}disabled{% endif %}>
                                                <option value="user_field" {% if mapping.target_type == 'user_field' %}selected{% endif %}>{{ __('User Field', plugin) }}</option>
                                                <option value="rule_field" {% if mapping.target_type == 'rule_field' %}selected{% endif %}>{{ __('Rule Field', plugin) }}</option>
                                            </select>
                                        </td>
                                        <td>
                                            {% if is_system_required %}
                                                <input type="hidden" name="claim_map[{{ index }}][glpi_field]" value="{{ mapping.glpi_field }}">
                                            {% endif %}
                                            <select name="claim_map[{{ index }}][glpi_field]" class="form-select glpi-field-select" {% if is_system_required %}disabled{% endif %}>
                                                {% if mapping.target_type == 'rule_field' %}
                                                    {% for field in allowed_rule_fields %}
                                                        <option value="{{ field }}" {% if mapping.glpi_field == field %}selected{% endif %}>{{ field|title }}</option>
                                                    {% endfor %}
                                                {% else %}
                                                    {% for field in allowed_user_fields %}
                                                        <option value="{{ field }}" {% if mapping.glpi_field == field %}selected{% endif %}>{{ field|title }}</option>
                                                    {% endfor %}
                                                {% endif %}
                                            </select>
                                        </td>
                                        <td>
                                            {% if is_username_locked %}
                                                <input type="hidden" name="claim_map[{{ index }}][saml_claim]" value="NameId">
                                            {% endif %}
                                            <div class="input-group">
                                                <input type="text" name="claim_map[{{ index }}][saml_claim]" value="{{ is_username_locked ? 'NameId' : mapping.saml_claim }}" class="form-control saml-claim-input" oninput="checkObserved(this)" {% if is_username_locked %}disabled{% else %}list="observed_claims_list"{% endif %}>
                                                {% if not is_username_locked and observed_claims is not empty %}
                                                    <button class="btn btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" data-bs-boundary="viewport" aria-expanded="false"></button>
                                                    <ul class="dropdown-menu dropdown-menu-end" style="max-height: 200px; overflow-y: auto;">
                                                        {% for claim in observed_claims %}
