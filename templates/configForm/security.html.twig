                            {
                                'add_field_html': error_helper|raw,
                                helper: inputfields.security_wantnameid.formexplain,
                            }) 
                        }}
                    </div>
                </div>

                <!-- Group 4: Outbound Security (SP) -->
                <div class="samlsso-category-header">
                    <i class="fas fa-sign-out-alt me-2 text-success"></i>{{ __('Outbound Security (SP)', plugin) }}
