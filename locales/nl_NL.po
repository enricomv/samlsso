msgstr "Het FontAwesome (%s)-pictogram dat op de knop op de inlogpagina moet worden weergegeven."

#: src/Config/ConfigItem.php:354
msgid "LOGIN ICON"
msgstr "INLOG-PICTOGRAM"

#: src/Config/ConfigItem.php:359
msgid "⭕ Configuration icon is a required field"
msgstr "⭕ Het configuratiepictogram is een verplicht veld"

#: src/Config/ConfigItem.php:366
