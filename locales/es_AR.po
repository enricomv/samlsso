msgstr "COMPARACIÓN DE AUTHN"

#: src/Config/ConfigItem.php:348
msgid "⭕ Requested authN context comparison is a required field"
msgstr "⭕ La comparación del contexto de autenticación solicitada es un campo obligatorio"

